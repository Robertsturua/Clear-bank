<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Clear.Bank | Edit User</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    :root {
      --admin-navy: #051024;
      --admin-cyan: #00E5C4; --bg-color: #f4f7f9; 
      --surface: #ffffff; --text-main: #051024; --text-muted: #64748b; 
      --border: #e2e8f0; --font: 'Inter', sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: var(--font); }
    body { background-color: var(--bg-color); color: var(--text-main); display: flex; height: 100vh; overflow: hidden; }
    
    .sidebar { width: 280px; background: var(--admin-navy); color: white; display: flex; flex-direction: column; padding: 24px 20px; }
    .brand { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 40px; padding: 0 12px; display: flex; align-items: center; gap: 10px; }
    .nav-menu { display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .nav-link { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border-radius: 12px; color: #94a3b8; text-decoration: none; font-weight: 600; font-size: 14px; transition: 0.2s; }
    .nav-link:hover { background: rgba(255,255,255,0.05); color: white; }
    .nav-link.active { background: var(--admin-cyan); color: var(--admin-navy); }
    .nav-link svg { width: 18px; height: 18px; }
    
    .main-content { flex: 1; overflow-y: auto; padding: 40px; }
    .page-header { margin-bottom: 32px; display: flex; align-items: center; gap: 16px; }
    .page-header h1 { font-size: 28px; font-weight: 800; letter-spacing: -0.5px; }
    .badge-id { background: var(--border); color: var(--text-muted); padding: 4px 12px; border-radius: 20px; font-family: monospace; font-size: 14px; font-weight: 700; }
    
    .grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 24px; align-items: start; }
    .card { background: var(--surface); border-radius: 16px; padding: 24px; border: 1px solid var(--border); margin-bottom: 24px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); }
    .card h3 { margin-bottom: 20px; font-size: 16px; font-weight: 800; border-bottom: 1px solid var(--border); padding-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 12px; font-weight: 700; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    .form-group input, .form-group select { width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; font-family: var(--font); outline: none; transition: 0.2s; background: var(--bg-color); }
    .form-group input:focus, .form-group select:focus { border-color: var(--admin-navy); background: white; }
    
    .btn { background: var(--admin-navy); color: white; border: none; padding: 12px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; width: 100%; font-size: 14px; transition: 0.2s; display: flex; justify-content: center; align-items: center; gap: 8px; }
    .btn:hover { opacity: 0.9; }
    .btn-danger { background: #ef4444; }
    .btn-success { background: #10b981; }
    .btn-outline { background: white; color: var(--admin-navy); border: 1px solid var(--border); }
    
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    th { text-align: left; padding: 12px 8px; border-bottom: 1px solid var(--border); color: var(--text-muted); text-transform: uppercase; font-size: 11px; font-weight: 700; }
    td { padding: 16px 8px; border-bottom: 1px solid var(--border); vertical-align: middle; }
    
    .password-vault { background: #fefce8; border: 1px solid #fde047; padding: 16px; border-radius: 12px; margin-bottom: 24px; }
    .password-vault label { color: #854d0e; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 4px; }
    .password-vault .code { font-family: monospace; font-size: 20px; font-weight: 700; color: #111827; }

    /* Edit Modal Overlay */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: none; align-items: center; justify-content: center; }
    .modal-content { background: white; width: 400px; padding: 24px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="brand"><i data-lucide="shield-check"></i> God Mode</div>
    <nav class="nav-menu">
      <a href="/admin" class="nav-link"><i data-lucide="layout-dashboard"></i> Control Center</a>
      <a href="/admin/users" class="nav-link" style="background: rgba(255,255,255,0.1);"><i data-lucide="arrow-left"></i> Back to Users</a>
      <a href="/admin/comms" class="nav-link"><i data-lucide="message-square"></i> Communications</a>
    </nav>
  </aside>
  
  <main class="main-content">
    <div class="page-header">
      <h1>Managing @<%= client.username %></h1>
      <span class="badge-id">ID: #<%= String(client.id).padStart(3, '0') %></span>
    </div>
    
    <div class="grid">
      <div style="display: flex; flex-direction: column; gap: 24px;">
        
        <div class="card" style="margin-bottom: 0;">
          <h3><i data-lucide="award"></i> Account Limits & Tiers</h3>
          
          <% if (account.tier_status === 'PENDING') { %>
             <div style="background: #fefce8; border: 1px solid #fde047; padding: 16px; border-radius: 12px; margin-bottom: 20px;">
                <strong style="color: #854d0e;">Upgrade Requested!</strong><br>
                <span style="font-size: 13px; color: #a16207;">User requested upgrade to the <strong><%= account.requested_tier %> Plan</strong></span>
                <div style="display:flex; gap: 8px; margin-top: 12px;">
                   <form action="/admin/user/<%= client.id %>/approve_tier" method="POST" style="flex: 1;" onsubmit="return verifyAction('Approve Limit Increase');">
                     <button class="btn btn-success">Approve</button>
                   </form>
                   <form action="/admin/user/<%= client.id %>/reject_tier" method="POST" style="flex: 1;" onsubmit="return verifyAction('Decline Limit Increase');">
                     <button class="btn btn-danger">Decline</button>
                   </form>
                </div>
             </div>
          <% } %>

          <form action="/admin/user/<%= client.id %>/set_tier" method="POST">
             <div class="form-group">
                <label>Current Plan</label>
                <select name="account_tier">
                   <option value="Basic" <%= account.account_tier === 'Basic' ? 'selected' : '' %>>Basic Plan (€10,000 Limit)</option>
                   <option value="Standard" <%= account.account_tier === 'Standard' ? 'selected' : '' %>>Standard Plan (€50,000 Limit)</option>
                   <option value="Premium" <%= account.account_tier === 'Premium' ? 'selected' : '' %>>Premium Plan (€100,000 Limit)</option>
                   <option value="VIP" <%= account.account_tier === 'VIP' ? 'selected' : '' %>>VIP Plan (€250,000 Limit)</option>
                </select>
             </div>
             <button type="submit" class="btn btn-outline">Force Change Plan</button>
          </form>
        </div>

        <div class="card" style="margin-bottom: 0;">
          <h3><i data-lucide="database"></i> Core Data & Financials</h3>
          <form action="/admin/user/<%= client.id %>/edit" method="POST">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <div class="form-group"><label>Main Fiat Balance (€)</label><input type="number" step="0.01" name="fiat_balance" value="<%= (account.fiat_cents / 100).toFixed(2) %>"></div>
              <div class="form-group"><label>Savings Balance (€)</label><input type="number" step="0.01" name="hisa_balance" value="<%= (account.hisa_cents ? account.hisa_cents / 100 : 0).toFixed(2) %>"></div>
              <div class="form-group"><label>BTC Balance (₿)</label><input type="number" step="0.00000001" name="btc_balance" value="<%= (account.btc_sats / 100000000).toFixed(8) %>"></div>
              <div class="form-group"><label>ETH Balance (⟠)</label><input type="number" step="0.00000001" name="eth_balance" value="<%= (account.eth_sats / 100000000).toFixed(8) %>"></div>
              
              <div class="form-group" style="grid-column: 1 / -1;"><label>Full Name</label><input type="text" name="full_name" value="<%= profile.full_name %>"></div>
              <div class="form-group"><label>Date of Birth</label><input type="text" name="dob" value="<%= profile.dob %>" placeholder="YYYY-MM-DD"></div>
              <div class="form-group"><label>Phone Number</label><input type="text" name="phone" value="<%= profile.phone %>"></div>
              <div class="form-group" style="grid-column: 1 / -1;"><label>Email</label><input type="text" name="email" value="<%= profile.email %>"></div>

              <div class="form-group" style="grid-column: 1 / -1;"><label>Street Address</label><input type="text" name="street" value="<%= profile.street %>"></div>
              <div class="form-group"><label>City</label><input type="text" name="city" value="<%= profile.city %>"></div>
              <div class="form-group"><label>State / Province</label><input type="text" name="state" value="<%= profile.state %>"></div>
              <div class="form-group"><label>Postal Code</label><input type="text" name="postal_code" value="<%= profile.postal_code %>"></div>
              <div class="form-group"><label>Country</label><input type="text" name="country" value="<%= profile.country %>"></div>

              <div class="form-group" style="grid-column: 1 / -1;"><label>IBAN</label><input type="text" name="iban" value="<%= account.iban %>" style="font-family: monospace;"></div>
              <div class="form-group" style="grid-column: 1 / -1;"><label>SWIFT</label><input type="text" name="swift" value="<%= account.swift %>" style="font-family: monospace;"></div>
              
              <div class="form-group" style="grid-column: 1 / -1;"><label>BTC Address</label><input type="text" name="btc_address" value="<%= account.btc_address %>" style="font-family: monospace;"></div>
              <div class="form-group" style="grid-column: 1 / -1;"><label>ETH Address</label><input type="text" name="eth_address" value="<%= account.eth_address %>" style="font-family: monospace;"></div>
            </div>
            <button type="submit" class="btn" style="margin-top: 24px;">Overwrite User Data</button>
          </form>
        </div>

        <div class="card" style="border: 2px dashed var(--admin-cyan); background: #f0fdfa;">
          <h3 style="color: #0f766e; border-color: #ccfbf1;"><i data-lucide="download"></i> Add / Inject Transaction</h3>
          <p style="font-size: 13px; color: #0f766e; margin-bottom: 16px;">Create a new pending deposit in the user's ledger.</p>
          <form action="/admin/user/<%= client.id %>/inject" method="POST" onsubmit="return verifyAction('Inject Funds');">
            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 16px;">
              
              <div class="form-group">
                <label>Currency</label>
                <select name="currency" id="injectCurrency" onchange="updateInjectForm()">
                  <option value="EUR">Euro (EUR)</option>
                  <option value="BTC">Bitcoin (BTC)</option>
                  <option value="ETH">Ethereum (ETH)</option>
                </select>
              </div>
              
              <div class="form-group">
                <label>Amount</label>
                <input type="number" step="0.01" name="amount" id="injectAmount" required placeholder="0.00">
              </div>
              
              <div class="form-group" style="grid-column: 1 / -1;">
                <label id="injectSenderNameLabel">Sender Name</label>
                <input type="text" name="sender_name" required placeholder="e.g. Coinbase or John Doe">
              </div>
              
              <div class="form-group" style="grid-column: 1 / -1;">
                <label id="injectSenderLabel">Sender IBAN</label>
                <input type="text" name="sender_iban" id="injectSenderInput" placeholder="Optional reference">
              </div>

              <div class="form-group" style="grid-column: 1 / -1;">
                <label>Custom Date</label>
                <input type="text" name="custom_date" placeholder="Leave empty for today">
              </div>
            </div>
            <button type="submit" class="btn" style="background: #0f766e;">Create Transaction</button>
          </form>
        </div>
      </div>

      <div>
        <div class="card">
          <h3><i data-lucide="shield"></i> Security & Access</h3>
          <div class="password-vault">
            <label>Registration Password</label>
            <div class="code"><%= client.initial_password || 'Not recorded' %></div>
          </div>
          
          <form action="/admin/user/<%= client.id %>/status" method="POST" onsubmit="return verifyAction('Change Account Status');">
            <div class="form-group">
              <label>Account Status</label>
              <select name="status">
                <option value="PENDING" <%= client.status === 'PENDING' ? 'selected' : '' %>>PENDING (Awaiting Verification)</option>
                <option value="ACTIVE" <%= client.status === 'ACTIVE' ? 'selected' : '' %>>ACTIVE (Normal Access)</option>
                <option value="SUSPENDED" <%= client.status === 'SUSPENDED' ? 'selected' : '' %>>SUSPENDED (Cannot send)</option>
                <option value="LOCKED" <%= client.status === 'LOCKED' ? 'selected' : '' %>>LOCKED (Cannot log in)</option>
              </select>
            </div>
            <button type="submit" class="btn btn-danger" style="<%= client.status === 'PENDING' ? 'background:#10b981;' : '' %>">
              <%= client.status === 'PENDING' ? 'Approve Account' : 'Change Status' %>
            </button>
          </form>
          
          <div style="margin-top: 24px; border-top: 1px solid var(--border); padding-top: 24px; display: flex; flex-direction: column; gap: 12px;">
            <label style="font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase;">Feature Toggles</label>
            <div style="display: flex; gap: 8px;">
              <form action="/admin/user/<%= client.id %>/toggle/hisa" method="POST" style="flex: 1;">
                <input type="hidden" name="current_status" value="<%= account.hisa_status %>">
                <button type="submit" class="btn btn-outline"><%= account.hisa_status === 'ACTIVE' ? 'Close HISA' : 'Force Open HISA' %></button>
              </form>
              <form action="/admin/user/<%= client.id %>/toggle_tier" method="POST" style="flex: 1;">
                <input type="hidden" name="current_tier" value="<%= account.hisa_tier || 'Standard' %>">
                <button type="submit" class="btn btn-outline" <%= account.hisa_status !== 'ACTIVE' ? 'disabled style="opacity:0.5;"' : '' %>>
                  <%= account.hisa_tier === 'Premium' ? 'Downgrade HISA' : 'Upgrade HISA' %>
                </button>
              </form>
            </div>
            <div style="display: flex; gap: 8px;">
              <form action="/admin/user/<%= client.id %>/toggle/btc" method="POST" style="flex: 1;">
                <input type="hidden" name="current_status" value="<%= account.btc_status %>">
                <button type="submit" class="btn btn-outline" style="color: #F7931A; border-color: #F7931A;"><%= account.btc_status === 'ACTIVE' ? 'Disable BTC' : 'Enable BTC' %></button>
              </form>
              <form action="/admin/user/<%= client.id %>/toggle/eth" method="POST" style="flex: 1;">
                <input type="hidden" name="current_status" value="<%= account.eth_status %>">
                <button type="submit" class="btn btn-outline" style="color: #627EEA; border-color: #627EEA;"><%= account.eth_status === 'ACTIVE' ? 'Disable ETH' : 'Enable ETH' %></button>
              </form>
            </div>
          </div>
        </div>

        <div class="card">
          <h3><i data-lucide="key"></i> Force Reset Password</h3>
          <form action="/admin/user/<%= client.id %>/password" method="POST">
            <div class="form-group"><label>New Password</label><input type="text" name="new_password" required placeholder="Type new password"></div>
            <button type="submit" class="btn btn-outline">Overwrite Password</button>
          </form>
        </div>

        <div class="card" style="border: 1px solid #fca5a5; background: #fef2f2;">
          <h3 style="color: #991b1b; border-color: #fca5a5;"><i data-lucide="alert-triangle"></i> Danger Zone</h3>
          <p style="font-size: 13px; color: #991b1b; margin-bottom: 16px;">Permanently wipe this user, their balances, and their entire transaction history from the database. Cannot be undone.</p>
          <form action="/admin/user/<%= client.id %>/delete" method="POST" onsubmit="return verifyAction('PERMANENTLY DELETE USER');">
            <button type="submit" class="btn btn-danger">Delete User & Wipe Data</button>
          </form>
        </div>
      </div>
    </div>

    <div class="card">
      <h3><i data-lucide="list"></i> Transaction Ledger</h3>
      <table>
        <thead><tr><th>Action / Sender</th><th>Amount</th><th>Status</th><th>Date</th><th>Controls</th></tr></thead>
        <tbody>
          <% if (txs.length === 0) { %>
            <tr><td colspan="5" style="text-align: center; padding: 30px; color: var(--text-muted);">No transactions found in ledger.</td></tr>
          <% } else { %>
            <% txs.forEach(tx => { %>
              <tr>
                <td><strong><%= tx.name %></strong></td>
                <td style="font-weight: 700; color: <%= tx.direction === 'INCOMING' ? '#10b981' : 'inherit' %>;"><%= tx.direction === 'INCOMING' ? '+' : '-' %><%= tx.amount %></td>
                <td>
                  <span style="font-size: 11px; font-weight: 800; padding: 4px 8px; border-radius: 6px; background: <%= tx.status === 'PENDING' ? '#fefce8' : (tx.status === 'DECLINED' ? '#fef2f2' : '#f1f5f9') %>; color: <%= tx.status === 'PENDING' ? '#854d0e' : (tx.status === 'DECLINED' ? '#991b1b' : 'inherit') %>;"><%= tx.status %></span>
                </td>
                <td style="font-size: 13px; color: var(--text-muted);"><%= tx.date %></td>
                <td style="display: flex; gap: 8px; align-items: center;">
                  <% if (tx.status === 'PENDING') { %>
                    <form action="/admin/tx/<%= tx.id %>/approve" method="POST" onsubmit="return verifyAction('Approve Transaction');"><button class="btn btn-success" style="padding: 6px 12px; font-size: 12px; width: auto;">Approve</button></form>
                    <form action="/admin/tx/<%= tx.id %>/decline" method="POST" onsubmit="return verifyAction('Decline Transaction');"><button class="btn btn-danger" style="padding: 6px 12px; font-size: 12px; width: auto;">Decline</button></form>
                  <% } %>
                  
                  <button type="button" class="btn btn-outline" style="padding: 6px 12px; font-size: 12px; width: auto; color: var(--admin-navy); border-color: var(--border);" onclick="openEditTxModal('<%= tx.id %>', '<%= tx.name.replace(/'/g, "\\'") %>', '<%= tx.amount %>', '<%= tx.status %>', '<%= tx.date %>')">Edit</button>

                  <form action="/admin/tx/<%= tx.id %>/delete" method="POST" onsubmit="return verifyAction('Delete Transaction');">
                    <button class="btn btn-outline" style="padding: 6px 12px; font-size: 12px; width: auto; color: var(--text-muted); border-color: var(--border);">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <div id="txEditModal" class="modal-overlay">
    <div class="modal-content">
      <h2 style="margin-bottom: 20px; font-size: 20px; font-weight: 800;">Edit Transaction</h2>
      <form id="txEditForm" method="POST">
        <div class="form-group">
          <label>Sender / Action Name</label>
          <input type="text" name="tx_name" id="editTxName" required>
        </div>
        <div class="form-group">
          <label>Amount Label (Text e.g. "500.00 EUR" or "0.5 BTC")</label>
          <input type="text" name="tx_amount" id="editTxAmount" required>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select name="tx_status" id="editTxStatus">
            <option value="PENDING">PENDING</option>
            <option value="COMPLETED">COMPLETED</option>
            <option value="DECLINED">DECLINED</option>
          </select>
        </div>
        <div class="form-group">
          <label>Date String</label>
          <input type="text" name="tx_date" id="editTxDate" required>
        </div>
        
        <div style="display: flex; gap: 12px; margin-top: 24px;">
          <button type="button" class="btn btn-outline" onclick="closeEditTxModal()" style="flex: 1;">Cancel</button>
          <button type="submit" class="btn btn-success" style="flex: 1;">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    lucide.createIcons();

    // NEW: Dynamic UI for the Inject form
    function updateInjectForm() {
      const currency = document.getElementById('injectCurrency').value;
      const label = document.getElementById('injectSenderLabel');
      const input = document.getElementById('injectSenderInput');
      const amountInput = document.getElementById('injectAmount');

      if (currency === 'BTC' || currency === 'ETH') {
        label.innerText = 'Sender Wallet Address';
        input.placeholder = 'e.g. 0x... or bc1...';
        amountInput.step = '0.00000001';
      } else {
        label.innerText = 'Sender IBAN';
        input.placeholder = 'Optional reference';
        amountInput.step = '0.01';
      }
    }
    
    function verifyAction(actionName) {
      const expectedUsername = "<%= client.username %>";
      const userInput = prompt(`SECURITY CHECK\n\nTo confirm [ ${actionName} ], please type the client's exact username (${expectedUsername}) below:`);
      
      if (userInput === expectedUsername) { return true; } 
      else {
        if (userInput !== null) { alert("Verification failed. Username did not match. Action aborted."); }
        return false; 
      }
    }

    function openEditTxModal(id, name, amount, status, date) {
      document.getElementById('txEditForm').action = `/admin/tx/${id}/edit`;
      document.getElementById('editTxName').value = name;
      document.getElementById('editTxAmount').value = amount;
      document.getElementById('editTxStatus').value = status;
      document.getElementById('editTxDate').value = date;
      document.getElementById('txEditModal').style.display = 'flex';
    }

    function closeEditTxModal() {
      document.getElementById('txEditModal').style.display = 'none';
    }
  </script>
</body>
</html>