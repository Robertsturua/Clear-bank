<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Make a Payment</title>
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="white" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/mobile.css">
  
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <style>
    body { background-color: var(--mob-bg); overflow-x: hidden; }
    
    /* PC Desktop Constraint */
    @media (min-width: 768px) {
      body { max-width: 480px; margin: 0 auto; border-left: 1px solid var(--mob-border); border-right: 1px solid var(--mob-border); box-shadow: 0 0 50px rgba(0,0,0,0.1); position: relative; min-height: 100vh; }
      .mob-bottom-nav, .modal-sheet, .success-overlay, .toast-notif, .ios-modal-sheet { max-width: 480px; margin: 0 auto; left: 0; right: 0; }
    }
    
    /* Header with Plus Button & Profile */
    .send-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; padding-top: max(20px, env(safe-area-inset-top)); background: var(--mob-bg); position: sticky; top: 0; z-index: 100; }
    .send-header h1 { margin: 0; font-size: 20px; font-weight: 800; color: var(--mob-text); }
    .btn-icon { background: var(--mob-surface); border: 1px solid var(--mob-border); width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--mob-text); box-shadow: var(--mob-shadow-sm); transition: 0.2s; }
    .btn-icon:active { transform: scale(0.95); }

    /* Saved Contacts Horizontal Scroller */
    .section-title { margin: 10px 24px 12px 24px; font-size: 13px; font-weight: 700; color: var(--mob-text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
    
    .contacts-scroller { display: flex; gap: 16px; padding: 0 20px 24px 20px; overflow-x: auto; scrollbar-width: none; }
    .contacts-scroller::-webkit-scrollbar { display: none; }
    
    .contact-bubble { display: flex; flex-direction: column; align-items: center; gap: 8px; cursor: pointer; min-width: 64px; transition: transform 0.2s; }
    .contact-bubble:active { transform: scale(0.95); }
    
    .contact-avatar { width: 56px; height: 56px; background: var(--mob-primary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 800; box-shadow: var(--mob-shadow-sm); border: 2px solid white; }
    .contact-name { font-size: 12px; font-weight: 600; color: var(--mob-text); text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 72px; }

    .empty-contacts { background: var(--mob-surface); border: 1px dashed var(--mob-border); border-radius: 16px; padding: 20px; margin: 0 20px 24px 20px; text-align: center; font-size: 13px; color: var(--mob-text-muted); font-weight: 500; }

    /* Main Transfer Form */
    .transfer-box { background: var(--mob-surface); border: 1px solid var(--mob-border); border-radius: 20px; padding: 24px 20px; margin: 0 20px 24px 20px; box-shadow: var(--mob-shadow-sm); }
    
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--mob-text); margin-bottom: 8px; }
    .form-control { width: 100%; box-sizing: border-box; background: var(--mob-bg); border: 1px solid var(--mob-border); padding: 14px 16px; border-radius: 12px; font-size: 15px; outline: none; transition: 0.2s; font-family: 'Inter', sans-serif; color: var(--mob-text); }
    .form-control:focus { border-color: var(--mob-primary); box-shadow: 0 0 0 3px var(--mob-primary-dim); background: var(--mob-surface); }
    .form-control.monospace { font-family: monospace; font-size: 14px; letter-spacing: 0.5px; }
    .form-control:disabled { background-color: #f3f4f6; color: #9ca3af; cursor: not-allowed; }

    .amount-wrapper { position: relative; display: flex; align-items: center; }
    .amount-wrapper span { position: absolute; left: 16px; font-weight: 600; color: var(--mob-text-muted); font-size: 18px; }
    .amount-wrapper input { padding-left: 36px; font-weight: 800; font-size: 24px; color: var(--mob-primary); letter-spacing: -0.5px; }
    
    .btn-continue { background: var(--mob-primary); color: white; border: none; padding: 16px; border-radius: 16px; font-weight: 700; font-size: 16px; width: calc(100% - 40px); margin: 0 20px; cursor: pointer; box-shadow: var(--mob-shadow-md); transition: transform 0.2s; display: block; text-align: center; }
    .btn-continue:active:not(:disabled) { transform: scale(0.98); }
    .btn-continue:disabled { opacity: 0.5; cursor: not-allowed; }

    /* Bottom Sheet Modals */
    .modal-overlay { position: fixed; inset: 0; background: rgba(5, 16, 36, 0.6); z-index: 300; display: none; opacity: 0; transition: opacity 0.3s; }
    .modal-sheet { position: fixed; bottom: 0; left: 0; right: 0; background: var(--mob-bg); border-radius: 24px 24px 0 0; z-index: 301; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); padding: 24px; padding-bottom: max(24px, env(safe-area-inset-bottom)); max-height: 90vh; overflow-y: auto; }
    .modal-sheet.open { transform: translateY(0); }
    .modal-overlay.open { display: block; opacity: 1; }
    
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .modal-header h2 { margin: 0; font-size: 20px; font-weight: 800; color: var(--mob-text); }
    .modal-close-btn { background: var(--mob-surface); border: 1px solid var(--mob-border); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; }

    /* Confirmation Sheet Details */
    .confirm-details { background: var(--mob-surface); border-radius: 16px; border: 1px solid var(--mob-border); padding: 8px 20px; margin-bottom: 24px; }
    .confirm-row { display: flex; justify-content: space-between; align-items: center; padding: 16px 0; border-bottom: 1px solid var(--mob-border); }
    .confirm-row:last-child { border-bottom: none; }
    .confirm-label { font-size: 14px; color: var(--mob-text-muted); font-weight: 500; }
    .confirm-value { font-size: 15px; color: var(--mob-text); font-weight: 700; text-align: right; }
    
    .btn-submit-transfer { background: var(--mob-accent); color: var(--mob-primary); border: none; padding: 16px 20px; border-radius: 16px; font-weight: 800; font-size: 16px; width: 100%; cursor: pointer; box-shadow: 0 8px 20px rgba(0, 229, 196, 0.2); display: flex; justify-content: center; align-items: center; gap: 8px;}

    /* Success Screen Overlay */
    .success-overlay { position: fixed; inset: 0; background: var(--mob-bg); z-index: 400; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; text-align: center; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
    .success-overlay.show { opacity: 1; pointer-events: auto; }
    .success-icon-wrap { width: 80px; height: 80px; background: #fef3c7; color: #f59e0b; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; transform: scale(0.5); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    .success-overlay.show .success-icon-wrap { transform: scale(1); }
    .success-icon-wrap svg { width: 40px; height: 40px; stroke-width: 3px; }

    /* Custom Toast Notification */
    .toast-notif { position: fixed; top: 20px; left: 50%; transform: translateX(-50%) translateY(-100px); background: var(--mob-primary); color: white; padding: 12px 24px; border-radius: 20px; font-size: 14px; font-weight: 600; box-shadow: var(--mob-shadow-md); z-index: 999; transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); text-align: center; width: auto; white-space: nowrap; }
    .toast-notif.show { transform: translateX(-50%) translateY(0); }

    /* IOS MODAL STYLES */
    .ios-modal-overlay { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 1000; display: none; opacity: 0; transition: opacity 0.3s; }
    .ios-modal-sheet { position: fixed; bottom: 0; left: 0; right: 0; background: var(--mob-bg); border-radius: 24px 24px 0 0; z-index: 1001; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); padding: 32px 24px; padding-bottom: max(32px, env(safe-area-inset-bottom)); text-align: center; }
    .ios-modal-sheet.open { transform: translateY(0); }
    .ios-modal-overlay.open { display: block; opacity: 1; }
    .ios-modal-icon { width: 64px; height: 64px; background: #f3f4f6; border-radius: 16px; margin: 0 auto 20px auto; display: flex; align-items: center; justify-content: center; }
    .ios-modal-icon img { width: 40px; height: 40px; }
    .ios-modal-sheet h3 { font-size: 22px; font-weight: 800; color: var(--mob-text); margin-bottom: 12px; letter-spacing: -0.5px; }
    .ios-modal-sheet p { font-size: 16px; color: var(--mob-text-muted); line-height: 1.5; margin-bottom: 24px; }
    .ios-steps { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 16px; padding: 20px; text-align: left; margin-bottom: 24px; }
    .ios-step { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; font-size: 15px; font-weight: 600; color: var(--mob-text); }
    .ios-step:last-child { margin-bottom: 0; }
    .btn-got-it { background: var(--mob-text); color: var(--mob-bg); border: none; width: 100%; padding: 16px; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; }

    @keyframes spin { 100% { transform: rotate(360deg); } }
  </style>
</head>
<body>

  <div id="toast" class="toast-notif">Message</div>

  <form id="transferForm" action="/send" method="POST" style="display: none;">
    <input type="hidden" name="recipientName" id="hiddenName">
    <input type="hidden" name="recipientIban" id="hiddenIban">
    <input type="hidden" name="recipientSwift" id="hiddenSwift">
    <input type="hidden" name="amount" id="hiddenAmount">
    <input type="hidden" name="currency_type" value="eur">
  </form>

  <header class="send-header">
    <div style="display: flex; align-items: center; gap: 12px;">
      <button class="btn-icon" onclick="window.history.back()"><i data-lucide="arrow-left" style="width: 18px;"></i></button>
      <h1 style="margin: 0; font-size: 20px; font-weight: 800; color: var(--mob-text);">Make a Payment</h1>
    </div>
    <div style="display: flex; gap: 8px; align-items: center;">
      <button class="pwa-install-btn" style="display: none; background: var(--mob-accent); color: var(--mob-primary); border: none; padding: 6px 12px; border-radius: 20px; font-weight: 800; font-size: 13px; align-items: center; gap: 6px; cursor: pointer; box-shadow: var(--mob-shadow-sm);" onclick="triggerInstall()">
        App <i data-lucide="download" style="width: 14px; height: 14px;"></i>
      </button>
      <button class="btn-icon" onclick="openAddContactModal()"><i data-lucide="plus" style="width: 20px;"></i></button>
      <button class="mob-avatar-mini" onclick="openProfileMenu()">
        <%= typeof username !== 'undefined' && username ? username.charAt(0).toUpperCase() : 'U' %>
      </button>
    </div>
  </header>

  <main class="mob-main-content" style="padding-top: 10px; padding-bottom: 40px;">

    <% if (typeof userStatus !== 'undefined' && userStatus === 'SUSPENDED') { %>
      <div style="background: #fef2f2; border: 1px solid #fecaca; margin: 10px 20px 24px 20px; padding: 16px; border-radius: 16px; display: flex; align-items: flex-start; gap: 12px; box-shadow: var(--mob-shadow-sm);">
        <i data-lucide="shield-alert" style="color: #ef4444; flex-shrink: 0; width: 24px; height: 24px;"></i>
        <div>
          <h4 style="margin: 0 0 4px 0; color: #991b1b; font-size: 15px; font-weight: 700;">Account Suspended</h4>
          <p style="margin: 0; color: #b91c1c; font-size: 13px; line-height: 1.4;">You cannot send money at this time. Please contact Support@clearb.org for assistance.</p>
        </div>
      </div>
    <% } %>
    
    <h3 class="section-title">Saved Contacts</h3>
    
    <div id="emptyContactsState" class="empty-contacts">
      No saved contacts. Tap the '+' icon above to add someone.
    </div>
    
    <div class="contacts-scroller" id="contactsContainer" style="display: none;">
    </div>

    <h3 class="section-title">Transfer Details</h3>
    <div class="transfer-box">
      
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" id="tfName" class="form-control" placeholder="Recipient's legal name" required <%= (typeof userStatus !== 'undefined' && userStatus === 'SUSPENDED') ? 'disabled' : '' %>>
      </div>

      <div class="form-group">
        <label>IBAN</label>
        <input type="text" id="tfIban" class="form-control monospace" placeholder="Enter IBAN" required <%= (typeof userStatus !== 'undefined' && userStatus === 'SUSPENDED') ? 'disabled' : '' %>>
      </div>

      <div class="form-group">
        <label>BIC / SWIFT</label>
        <input type="text" id="tfSwift" class="form-control monospace" placeholder="Enter SWIFT code" required <%= (typeof userStatus !== 'undefined' && userStatus === 'SUSPENDED') ? 'disabled' : '' %>>
      </div>

      <div class="form-group" style="margin-bottom: 0;">
        <label>Amount</label>
        <div class="amount-wrapper">
          <span>€</span>
          <input type="text" inputmode="decimal" id="tfAmount" class="form-control" placeholder="0.00" required <%= (typeof userStatus !== 'undefined' && userStatus === 'SUSPENDED') ? 'disabled' : '' %>>
        </div>
        <div style="font-size: 12px; color: var(--mob-text-muted); margin-top: 8px; text-align: right; font-weight: 600;">
          Available: €<%= typeof fiatBalance !== 'undefined' ? fiatBalance.toLocaleString('en-US', {minimumFractionDigits: 2}) : '0.00' %>
        </div>
      </div>

    </div>

    <button class="btn-continue" onclick="openReviewModal()" <%= (typeof userStatus !== 'undefined' && userStatus === 'SUSPENDED') ? 'disabled style="opacity:0.5; cursor:not-allowed;"' : '' %>>Review Transfer</button>

  </main>

  <div class="modal-overlay" id="addContactOverlay" onclick="closeAddContactModal()"></div>
  <div class="modal-sheet" id="addContactSheet">
    <div class="modal-header">
      <h2>Add New Contact</h2>
      <button class="modal-close-btn" onclick="closeAddContactModal()"><i data-lucide="x" style="width: 16px; color: var(--mob-text);"></i></button>
    </div>
    
    <div class="form-group">
      <label>Nickname (Optional)</label>
      <input type="text" id="acNickname" class="form-control" placeholder="e.g. John's Chase Account">
    </div>
    <div class="form-group">
      <label>Full Name</label>
      <input type="text" id="acFullName" class="form-control" placeholder="Legal full name" required>
    </div>
    <div class="form-group">
      <label>IBAN</label>
      <input type="text" id="acIban" class="form-control monospace" placeholder="Enter IBAN" required>
    </div>
    <div class="form-group">
      <label>BIC / SWIFT</label>
      <input type="text" id="acSwift" class="form-control monospace" placeholder="Enter SWIFT" required>
    </div>
    
    <button class="btn-continue" style="width: 100%; margin: 0;" onclick="saveContact()">Save Contact</button>
  </div>

  <div class="modal-overlay" id="reviewOverlay" onclick="closeReviewModal()"></div>
  <div class="modal-sheet" id="reviewSheet">
    <div class="modal-header">
      <h2>Confirm Details</h2>
      <button class="modal-close-btn" onclick="closeReviewModal()"><i data-lucide="x" style="width: 16px; color: var(--mob-text);"></i></button>
    </div>
    
    <div class="confirm-details">
      <div class="confirm-row">
        <div class="confirm-label">Recipient</div>
        <div class="confirm-value" id="rvName">Name</div>
      </div>
      <div class="confirm-row">
        <div class="confirm-label">IBAN</div>
        <div class="confirm-value" id="rvIban" style="font-family: monospace; font-size: 13px;">IBAN</div>
      </div>
      <div class="confirm-row">
        <div class="confirm-label">SWIFT</div>
        <div class="confirm-value" id="rvSwift" style="font-family: monospace; font-size: 13px;">SWIFT</div>
      </div>
      <div class="confirm-row">
        <div class="confirm-label">Amount</div>
        <div class="confirm-value" id="rvAmount" style="font-size: 18px; color: var(--mob-primary);">€0.00</div>
      </div>
    </div>

    <button class="btn-submit-transfer" id="submitBtn" onclick="processTransfer()">Send Securely</button>
  </div>

  <div class="success-overlay" id="successScreen">
    <div class="success-icon-wrap"><i data-lucide="clock"></i> </div>
    <h2 style="margin: 0 0 8px 0; font-size: 24px; font-weight: 800; color: var(--mob-text); letter-spacing: -0.5px;">Transfer Pending</h2>
    <p style="margin: 0 0 32px 0; font-size: 15px; color: var(--mob-text-muted);">Your transfer is securely processing and awaits confirmation.</p>
    
    <h1 style="font-size: 48px; font-weight: 800; color: var(--mob-text); margin: 0 0 4px 0; letter-spacing: -1px;" id="successAmount">€0.00</h1>
    <p style="font-size: 16px; font-weight: 600; color: var(--mob-text-muted); margin: 0 0 40px 0;" id="successName">to Recipient</p>

    <button class="btn-continue" style="background: var(--mob-primary-dim); color: var(--mob-primary); width: 100%; margin:0;" onclick="window.location.href='/dashboard'">Back to Home</button>
  </div>

  <div class="ios-modal-overlay" id="iosModalOverlay" onclick="closeIOSModal()"></div>
  <div class="ios-modal-sheet" id="iosModalSheet">
    <div class="ios-modal-icon">
      <img src="https://cdn-icons-png.flaticon.com/512/6202/6202860.png" alt="App Logo" style="width: 40px; height: 40px;">
    </div>
    <h3>Install App</h3>
    <p>Install this application on your home screen for quick and easy access when you're on the go.</p>
    <div class="ios-steps">
      <div class="ios-step">
        <span>1.</span>
        <span>Tap the <strong>Share</strong> button at the bottom of Safari.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--cb-black);"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
      </div>
      <div class="ios-step">
        <span>2.</span>
        <span>Scroll down and select <strong>Add to Home Screen</strong>.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--cb-black);"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
      </div>
    </div>
    <button class="btn-got-it" onclick="closeIOSModal()">Got it!</button>
  </div>

  <script>
    lucide.createIcons();

    let savedContacts = [];
    const userBalance = <%= typeof fiatBalance !== 'undefined' ? fiatBalance : 0 %>;
    const DAILY_LIMIT = 25000;

    function showToast(msg, isError = false) {
      const toast = document.getElementById('toast');
      toast.innerText = msg;
      
      if (isError) {
        toast.style.background = '#ef4444';
      } else {
        toast.style.background = 'var(--mob-primary)';
      }

      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    const amountInput = document.getElementById('tfAmount');
    amountInput.addEventListener('input', function(e) {
      let val = this.value.replace(/[^\d.]/g, '');
      const parts = val.split('.');
      if (parts.length > 2) val = parts[0] + '.' + parts.slice(1).join('');
      if (val) {
        const splitVal = val.split('.');
        splitVal[0] = splitVal[0].replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        this.value = splitVal.join('.');
      } else {
        this.value = '';
      }
    });

    function openAddContactModal() {
      document.getElementById('acNickname').value = '';
      document.getElementById('acFullName').value = '';
      document.getElementById('acIban').value = '';
      document.getElementById('acSwift').value = '';
      document.getElementById('addContactOverlay').classList.add('open');
      setTimeout(() => document.getElementById('addContactSheet').classList.add('open'), 10);
    }

    function closeAddContactModal() {
      document.getElementById('addContactSheet').classList.remove('open');
      setTimeout(() => document.getElementById('addContactOverlay').classList.remove('open'), 300);
    }

    function saveContact() {
      const fullName = document.getElementById('acFullName').value.trim();
      const iban = document.getElementById('acIban').value.trim();
      const swift = document.getElementById('acSwift').value.trim();
      const nickname = document.getElementById('acNickname').value.trim() || fullName;
      if (!fullName || !iban || !swift) {
        showToast('Full Name, IBAN, and SWIFT are required.', true);
        return;
      }

      savedContacts.push({ nickname, fullName, iban, swift });
      closeAddContactModal();
      renderContacts();
      showToast('Contact Saved');
    }

    function renderContacts() {
      const emptyState = document.getElementById('emptyContactsState');
      const scroller = document.getElementById('contactsContainer');
      if (savedContacts.length === 0) {
        emptyState.style.display = 'block';
        scroller.style.display = 'none';
        return;
      }

      emptyState.style.display = 'none';
      scroller.style.display = 'flex';
      scroller.innerHTML = '';
      savedContacts.forEach((contact, index) => {
        const initials = contact.nickname.split(' ').map(n => n[0]).join('').substring(0,2).toUpperCase();
        const bubble = document.createElement('div');
        bubble.className = 'contact-bubble';
        bubble.onclick = () => applyContact(index);
        bubble.innerHTML = `
          <div class="contact-avatar">${initials}</div>
          <div class="contact-name">${contact.nickname}</div>
        `;
        scroller.appendChild(bubble);
      });
    }

    function applyContact(index) {
      const contact = savedContacts[index];
      document.getElementById('tfName').value = contact.fullName;
      document.getElementById('tfIban').value = contact.iban;
      document.getElementById('tfSwift').value = contact.swift;
      showToast('Details applied');
    }

    function openReviewModal() {
      const name = document.getElementById('tfName').value.trim();
      const iban = document.getElementById('tfIban').value.trim();
      const swift = document.getElementById('tfSwift').value.trim();
      const rawAmountInput = document.getElementById('tfAmount').value;
      
      const sanitizedAmountStr = rawAmountInput.replace(/,/g, '');
      const amount = parseFloat(sanitizedAmountStr);
      if (!name || !iban || !swift || !rawAmountInput || isNaN(amount) || amount <= 0) {
        showToast("Please fill out all fields correctly.", true);
        return;
      }

      if (amount > userBalance) {
        showToast("Error: Insufficient funds in your account.", true);
        return;
      }

      if (amount > DAILY_LIMIT) {
        showToast(`Error: Transfer exceeds your daily limit of €${DAILY_LIMIT.toLocaleString('en-US', {minimumFractionDigits: 2})}`, true);
        return;
      }

      document.getElementById('hiddenName').value = name;
      document.getElementById('hiddenIban').value = iban;
      document.getElementById('hiddenSwift').value = swift;
      document.getElementById('hiddenAmount').value = amount;
      document.getElementById('rvName').innerText = name;
      document.getElementById('rvIban').innerText = iban.substring(0, 16) + '...';
      document.getElementById('rvSwift').innerText = swift;
      document.getElementById('rvAmount').innerText = '€' + amount.toLocaleString('en-US', {minimumFractionDigits: 2});
      const btn = document.getElementById('submitBtn');
      btn.innerHTML = 'Send Securely';
      btn.style.opacity = '1';
      btn.style.pointerEvents = 'auto';

      document.getElementById('reviewOverlay').classList.add('open');
      setTimeout(() => document.getElementById('reviewSheet').classList.add('open'), 10);
    }

    function closeReviewModal() {
      document.getElementById('reviewSheet').classList.remove('open');
      setTimeout(() => document.getElementById('reviewOverlay').classList.remove('open'), 300);
    }

    function processTransfer() {
      const btn = document.getElementById('submitBtn');
      btn.innerHTML = '<i data-lucide="loader-2" style="animation: spin 1s linear infinite; width: 20px;"></i> Processing...';
      lucide.createIcons();
      btn.style.opacity = '0.8';
      btn.style.pointerEvents = 'none';
      // Submit the form to your backend where you will save status='Pending'
      document.getElementById('transferForm').submit();
    }

    // ADVANCED PWA INSTALL LOGIC (APPLE BYPASS)
    let deferredPrompt;
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;

    if (!isStandalone) {
      if (isIOS) {
        document.querySelectorAll('.pwa-install-btn').forEach(btn => {
          btn.style.display = 'inline-flex';
        });
      } else {
        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;
          document.querySelectorAll('.pwa-install-btn').forEach(btn => {
            btn.style.display = 'inline-flex';
          });
        });
      }
    }

    function triggerInstall() {
      if (isIOS) {
        document.getElementById('iosModalOverlay').classList.add('open');
        setTimeout(() => document.getElementById('iosModalSheet').classList.add('open'), 10);
      } else if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then((choiceResult) => {
          deferredPrompt = null;
        });
      }
    }

    function closeIOSModal() {
      document.getElementById('iosModalSheet').classList.remove('open');
      setTimeout(() => document.getElementById('iosModalOverlay').classList.remove('open'), 300);
    }
  </script>

  <%- include('partials/profile_menu') %>
</body>
</html>