<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Clear.Bank | Savings Vault</title>
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="white" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/mobile.css">
  
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <style>
    body { background-color: var(--mob-bg); overflow-x: hidden; }
    
    /* PC Desktop Constraint */
    @media (min-width: 768px) {
      body { max-width: 480px; margin: 0 auto; border-left: 1px solid var(--mob-border); border-right: 1px solid var(--mob-border); box-shadow: 0 0 50px rgba(0,0,0,0.1); position: relative; min-height: 100vh; }
      .mob-bottom-nav, .ios-modal-sheet { max-width: 480px; margin: 0 auto; left: 0; right: 0; }
    }
    
    .vault-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; padding-top: max(20px, env(safe-area-inset-top)); background: var(--mob-bg); position: sticky; top: 0; z-index: 100; }
    .vault-header h1 { margin: 0; font-size: 20px; font-weight: 800; color: var(--mob-text); }
    .btn-back { background: var(--mob-surface); border: 1px solid var(--mob-border); width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--mob-text); box-shadow: var(--mob-shadow-sm); }
    
    /* Promotional View (Inactive) */
    .promo-hero { background: var(--mob-primary); border-radius: var(--mob-radius-lg); padding: 40px 24px; margin: 10px 20px 24px 20px; color: white; text-align: center; box-shadow: var(--mob-shadow-md); position: relative; overflow: hidden; }
    .promo-hero::after { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(0, 229, 196, 0.15) 0%, transparent 60%); pointer-events: none; }
    .promo-icon-wrap { width: 64px; height: 64px; background: var(--mob-accent); color: var(--mob-primary); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px auto; position: relative; z-index: 1; }
    .promo-hero h2 { font-size: 26px; font-weight: 800; margin: 0 0 12px 0; letter-spacing: -0.5px; position: relative; z-index: 1; }
    .promo-hero p { font-size: 15px; color: rgba(255,255,255,0.8); line-height: 1.5; margin: 0; position: relative; z-index: 1; }

    .feature-list { margin: 0 20px 32px 20px; display: flex; flex-direction: column; gap: 16px; }
    .feature-item { background: var(--mob-surface); border: 1px solid var(--mob-border); border-radius: 16px; padding: 20px; display: flex; gap: 16px; align-items: flex-start; box-shadow: var(--mob-shadow-sm); }
    .feature-icon { width: 40px; height: 40px; border-radius: 12px; background: var(--mob-primary-dim); color: var(--mob-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .feature-icon.premium { background: #fefce8; color: #d97706; }
    .feature-text h4 { margin: 0 0 4px 0; font-size: 15px; font-weight: 700; color: var(--mob-text); }
    .feature-text p { margin: 0; font-size: 13px; color: var(--mob-text-muted); line-height: 1.4; }

    .btn-activate { background: var(--mob-primary); color: white; border: none; padding: 16px 20px; border-radius: 16px; font-weight: 700; font-size: 16px; width: calc(100% - 40px); margin: 0 20px; cursor: pointer; box-shadow: var(--mob-shadow-md); transition: transform 0.2s; display: block; text-align: center; text-decoration: none; }
    .btn-activate:active { transform: scale(0.98); }

    /* Alert Boxes */
    .status-alert { margin: 10px 20px 24px 20px; padding: 20px; border-radius: 16px; display: flex; gap: 16px; align-items: flex-start; }
    .status-alert.review { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e3a8a; }
    .status-alert.error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }
    .status-icon { flex-shrink: 0; margin-top: 2px; }
    .status-alert h4 { margin: 0 0 4px 0; font-size: 15px; font-weight: 700; }
    .status-alert p { margin: 0; font-size: 13px; opacity: 0.9; line-height: 1.4; }

    /* Active Savings View */
    .savings-card { background: var(--mob-primary); color: white; border-radius: var(--mob-radius-lg); padding: 32px 24px; margin: 10px 20px 32px 20px; text-align: center; position: relative; overflow: hidden; box-shadow: var(--mob-shadow-md); }
    .savings-card::after { content: ''; position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: radial-gradient(circle, rgba(0, 229, 196, 0.2) 0%, transparent 70%); pointer-events: none; }
    .savings-card.premium { background: linear-gradient(135deg, #0f172a 0%, #000000 100%); border: 1px solid #d97706; }
    .savings-card.premium::after { background: radial-gradient(circle, rgba(217, 119, 6, 0.2) 0%, transparent 70%); }

    .savings-label { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.7); margin-bottom: 8px; }
    .savings-amount { font-size: 48px; font-weight: 800; letter-spacing: -1px; margin: 0 0 16px 0; }
    .savings-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; backdrop-filter: blur(4px); }
    .savings-card.premium .savings-badge { color: #fcd34d; border-color: rgba(245, 158, 11, 0.3); background: rgba(245, 158, 11, 0.1); }

    /* Transfer Box */
    .transfer-box { background: var(--mob-surface); border: 1px solid var(--mob-border); border-radius: 20px; padding: 24px; margin: 0 20px 24px 20px; box-shadow: var(--mob-shadow-sm); }
    .transfer-box h3 { font-size: 16px; font-weight: 800; margin: 0 0 20px 0; display: flex; align-items: center; gap: 8px; color: var(--mob-text); }
    
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--mob-text); margin-bottom: 8px; }
    
    .form-control { width: 100%; box-sizing: border-box; background: var(--mob-bg); border: 1px solid var(--mob-border); padding: 14px 16px; border-radius: 12px; font-size: 15px; outline: none; transition: 0.2s; font-family: 'Inter', sans-serif; color: var(--mob-text); }
    .form-control:focus { border-color: var(--mob-primary); box-shadow: 0 0 0 3px var(--mob-primary-dim); background: var(--mob-surface); }
    
    .amount-wrapper { position: relative; display: flex; align-items: center; }
    .amount-wrapper span { position: absolute; left: 16px; font-weight: 600; color: var(--mob-text-muted); font-size: 16px; }
    .amount-wrapper input { padding-left: 32px; font-weight: 700; font-size: 18px; }

    .available-text { font-size: 12px; color: var(--mob-text-muted); margin-top: 8px; font-weight: 600; display: flex; justify-content: space-between; }
    
    .btn-transfer { background: var(--mob-primary); color: white; border: none; padding: 16px; border-radius: 12px; font-weight: 700; width: 100%; cursor: pointer; font-size: 15px; transition: transform 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .btn-transfer:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-transfer:active:not(:disabled) { transform: scale(0.98); }

    .mob-nav-icon svg { width: 24px; height: 24px; stroke-width: 2px; margin-bottom: 2px; }

    /* IOS MODAL STYLES */
    .ios-modal-overlay { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 1000; display: none; opacity: 0; transition: opacity 0.3s; }
    .ios-modal-sheet { position: fixed; bottom: 0; left: 0; right: 0; background: var(--mob-bg); border-radius: 24px 24px 0 0; z-index: 1001; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); padding: 32px 24px; padding-bottom: max(32px, env(safe-area-inset-bottom)); text-align: center; }
    .ios-modal-sheet.open { transform: translateY(0); }
    .ios-modal-overlay.open { display: block; opacity: 1; }
    .ios-modal-icon { width: 64px; height: 64px; background: #f3f4f6; border-radius: 16px; margin: 0 auto 20px auto; display: flex; align-items: center; justify-content: center; }
    .ios-modal-sheet h3 { font-size: 22px; font-weight: 800; color: var(--mob-text); margin-bottom: 12px; letter-spacing: -0.5px; }
    .ios-modal-sheet p { font-size: 16px; color: var(--mob-text-muted); line-height: 1.5; margin-bottom: 24px; }
    .ios-steps { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 16px; padding: 20px; text-align: left; margin-bottom: 24px; }
    .ios-step { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; font-size: 15px; font-weight: 600; color: var(--mob-text); }
    .ios-step:last-child { margin-bottom: 0; }
    .btn-got-it { background: var(--mob-text); color: var(--mob-bg); border: none; width: 100%; padding: 16px; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; }
  </style>
</head>
<body>

  <header class="vault-header">
    <div style="display: flex; align-items: center; gap: 12px;">
      <button class="btn-back" onclick="window.history.back()"><i data-lucide="arrow-left" style="width: 18px;"></i></button>
      <h1>Savings Vault</h1>
    </div>
    
    <div style="display: flex; gap: 8px; align-items: center;">
      <button class="pwa-install-btn" style="display: none; background: var(--mob-accent); color: var(--mob-primary); border: none; padding: 6px 12px; border-radius: 20px; font-weight: 800; font-size: 13px; align-items: center; gap: 6px; cursor: pointer; box-shadow: var(--mob-shadow-sm);" onclick="triggerInstall()">
        App <i data-lucide="download" style="width: 14px; height: 14px;"></i>
      </button>
      <button class="mob-avatar-mini" onclick="openProfileMenu()">
        <%= typeof username !== 'undefined' && username ? username.charAt(0).toUpperCase() : 'U' %>
      </button>
    </div>
  </header>

  <main class="mob-main-content" style="padding-top: 0; padding-bottom: 100px;">

    <% if (account.hisa_status === 'INACTIVE') { %>
      <div class="promo-hero">
        <div class="promo-icon-wrap">
          <i data-lucide="piggy-bank" style="width: 32px; height: 32px; stroke-width: 2.5px;"></i>
        </div>
        
        <h2>Make your money work harder.</h2>
        <p>Earn industry-leading daily interest on your idle EUR balance with our High-Yield Vaults.</p>
      </div>
      
      <div class="feature-list">
        <div class="feature-item">
          <div class="feature-icon"><i data-lucide="trending-up"></i></div>
          <div class="feature-text">
            <h4>Top-Tier Yields</h4>
            <p>High yields paid out monthly directly to your savings.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon"><i data-lucide="zap"></i></div>
          <div class="feature-text">
            <h4>Instant Transfers</h4>
            <p>Move money instantly between accounts with no locking periods.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon premium"><i data-lucide="crown"></i></div>
          <div class="feature-text">
            <h4>Premium Upgrades</h4>
            <p>Upgrade to Premium for exclusive APY yield advantages.</p>
          </div>
        </div>
      </div>

      <% if (userStatus === 'ACTIVE') { %>
        <form action="/hisa/activate" method="POST">
          <button type="submit" class="btn-activate">Open Savings Vault</button>
        </form>
      <% } else { %>
        <div class="status-alert error">
          <div class="status-icon"><i data-lucide="alert-triangle"></i></div>
          <div>
            <h4>Verification Required</h4>
            <p>You must fully verify your main account before applying for a vault.</p>
          </div>
        </div>
      <% } %>

    <% } else if (account.hisa_status === 'PENDING') { %>
      <div class="status-alert review">
        <div class="status-icon"><i data-lucide="clipboard-list" style="width: 24px; height: 24px;"></i></div>
        <div>
          <h4>Application Under Review</h4>
          <p>Your account representative is reviewing your financial profile. This usually takes just a few minutes.</p>
        </div>
      </div>

    <% } else { %>
      
      <% if (userStatus === 'SUSPENDED') { %>
        <div class="status-alert error">
          <div class="status-icon"><i data-lucide="shield-alert"></i></div>
          <div>
            <h4>Account Suspended</h4>
            <p>Your account is under review. Transfers are temporarily disabled.</p>
          </div>
        </div>
      <% } %>

      <div class="savings-card <%= account.hisa_tier === 'Premium' ? 'premium' : '' %>">
        <div class="savings-label">Total Savings</div>
        <div class="savings-amount">€<%= hisaBalance.toLocaleString('en-US', {minimumFractionDigits: 2}) %></div>
        <div class="savings-badge">
          <% if (account.hisa_tier === 'Premium') { %>
            <i data-lucide="crown" style="width: 14px;"></i> Premium Yield Active
          <% } else { %>
            <i data-lucide="trending-up" style="width: 14px;"></i> Standard Yield Active
          <% } %>
        </div>
      </div>

      <div class="transfer-box">
        <h3><i data-lucide="arrow-right-left" style="color: var(--mob-primary); width: 20px;"></i> Vault Transfer</h3>
        
        <form action="/transfer/internal" method="POST">
          <div class="form-group">
            <label>Transfer Route</label>
            <select name="direction" id="routeSelect" class="form-control" onchange="updateRoute()" <%= userStatus === 'SUSPENDED' ? 'disabled' : '' %>>
              <option value="to_hisa">Main Account ➔ Savings Vault</option>
              <option value="to_main">Savings Vault ➔ Main Account</option>
            </select>
          </div>
          
          <input type="hidden" name="from_account" id="from_account" value="main">
          <input type="hidden" name="to_account" id="to_account" value="hisa">

          <div class="form-group">
            <label>Amount</label>
            <div class="amount-wrapper">
              <span>€</span>
              <input type="number" step="any" name="amount" class="form-control" placeholder="0.00" required <%= userStatus === 'SUSPENDED' ? 'disabled' : '' %>>
            </div>
            <div class="available-text">
              <span>Available to transfer:</span>
              <span id="availableText" style="color: var(--mob-text);">€<%= fiatBalance.toLocaleString('en-US', {minimumFractionDigits: 2}) %></span>
            </div>
          </div>
          
          <button type="submit" class="btn-transfer" <%= userStatus === 'SUSPENDED' ? 'disabled' : '' %>>
            Confirm Transfer
          </button>
        </form>
      </div>

    <% } %>

  </main>

  <div class="ios-modal-overlay" id="iosModalOverlay" onclick="closeIOSModal()"></div>
  <div class="ios-modal-sheet" id="iosModalSheet">
    <div class="ios-modal-icon">
      <img src="https://cdn-icons-png.flaticon.com/512/6202/6202860.png" alt="Clear.Bank" style="width: 40px; height: 40px;">
    </div>
    <h3>Install Clear.Bank App</h3>
    <p>Install this application on your home screen for quick and easy access when you're on the go.</p>
    <div class="ios-steps">
      <div class="ios-step">
        <span>1.</span>
        <span>Tap the <strong>Share</strong> button at the bottom of Safari.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--mob-text);"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
      </div>
      <div class="ios-step">
        <span>2.</span>
        <span>Scroll down and select <strong>Add to Home Screen</strong>.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--mob-text);"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
      </div>
    </div>
    <button class="btn-got-it" onclick="closeIOSModal()">Got it!</button>
  </div>

  <nav class="mob-bottom-nav">
    <a href="/dashboard" class="mob-nav-link">
      <span class="mob-nav-icon"><i data-lucide="home"></i></span>
      Home
    </a>
    <a href="/account" class="mob-nav-link">
      <span class="mob-nav-icon"><i data-lucide="credit-card"></i></span>
      Accounts
    </a>
    <a href="/transfers" class="mob-nav-link">
      <span class="mob-nav-icon"><i data-lucide="arrow-right-left"></i></span>
      Transactions
    </a>
    <a href="/support" class="mob-nav-link">
      <span class="mob-nav-icon"><i data-lucide="headphones"></i></span>
      Support
    </a>
  </nav>

  <script>
    lucide.createIcons();
    const fiatBal = <%= fiatBalance %>;
    const hisaBal = <%= hisaBalance %>;
    
    function updateRoute() {
      const route = document.getElementById('routeSelect').value;
      const from = document.getElementById('from_account');
      const to = document.getElementById('to_account');
      const avail = document.getElementById('availableText');

      if (route === 'to_hisa') {
        from.value = 'main';
        to.value = 'hisa';
        avail.innerText = `€${fiatBal.toLocaleString('en-US', {minimumFractionDigits: 2})}`;
      } else {
        from.value = 'hisa';
        to.value = 'main';
        avail.innerText = `€${hisaBal.toLocaleString('en-US', {minimumFractionDigits: 2})}`;
      }
    }

    // ADVANCED PWA INSTALL LOGIC (APPLE BYPASS)
    let deferredPrompt;
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;

    if (!isStandalone) {
      if (isIOS) {
        document.querySelectorAll('.pwa-install-btn').forEach(btn => { btn.style.display = 'flex'; });
      } else {
        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;
          document.querySelectorAll('.pwa-install-btn').forEach(btn => { btn.style.display = 'flex'; });
        });
      }
    }

    function triggerInstall() {
      if (isIOS) {
        document.getElementById('iosModalOverlay').classList.add('open');
        setTimeout(() => document.getElementById('iosModalSheet').classList.add('open'), 10);
      } else if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then((choiceResult) => { deferredPrompt = null; });
      }
    }

    function closeIOSModal() {
      document.getElementById('iosModalSheet').classList.remove('open');
      setTimeout(() => document.getElementById('iosModalOverlay').classList.remove('open'), 300);
    }
  </script>

  <%- include('partials/profile_menu') %>
</body>
</html>