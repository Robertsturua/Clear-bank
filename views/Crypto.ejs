<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Clear.Bank | Crypto Wallets</title>
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="white" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/mobile.css">
  
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <style>
    body { background-color: var(--mob-bg); overflow-x: hidden; }
    
    /* PC Desktop Constraint */
    @media (min-width: 768px) {
      body { max-width: 480px; margin: 0 auto; border-left: 1px solid var(--mob-border); border-right: 1px solid var(--mob-border); box-shadow: 0 0 50px rgba(0,0,0,0.1); position: relative; min-height: 100vh; }
      .mob-bottom-nav, .modal-sheet, .success-overlay, .toast-notif, .ios-modal-sheet { max-width: 480px; margin: 0 auto; left: 0; right: 0; }
    }
    
    .crypto-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; padding-top: max(20px, env(safe-area-inset-top)); background: var(--mob-bg); position: sticky; top: 0; z-index: 100; }
    .btn-back { background: var(--mob-surface); border: 1px solid var(--mob-border); width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--mob-text); box-shadow: var(--mob-shadow-sm); }

    .crypto-card { border-radius: var(--mob-radius-lg); padding: 24px; margin: 16px 20px; color: white; position: relative; overflow: hidden; box-shadow: var(--mob-shadow-md); }
    .crypto-card.btc { background: linear-gradient(135deg, #1e1b4b 0%, #000000 100%); border: 1px solid #f59e0b; }
    .crypto-card.eth { background: linear-gradient(135deg, #172554 0%, #000000 100%); border: 1px solid #3b82f6; }

    .crypto-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; position: relative; z-index: 1; }
    .cch-left { display: flex; align-items: center; gap: 12px; }
    .crypto-icon { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .btc .crypto-icon { background: rgba(245, 158, 11, 0.2); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.4); }
    .eth .crypto-icon { background: rgba(59, 130, 246, 0.2); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.4); }
    
    .crypto-title { font-size: 18px; font-weight: 800; margin: 0; }
    .crypto-subtitle { font-size: 13px; color: rgba(255,255,255,0.6); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
    .crypto-balance { font-size: 36px; font-weight: 800; letter-spacing: -1px; margin-bottom: 24px; position: relative; z-index: 1; word-break: break-all;}
    
    .wallet-address-box { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 1; backdrop-filter: blur(4px); margin-bottom: 16px; }
    .wallet-address { font-family: monospace; font-size: 13px; color: rgba(255,255,255,0.9); word-break: break-all; padding-right: 12px; }
    .btn-copy { background: transparent; border: none; color: white; cursor: pointer; padding: 4px; transition: 0.2s; }
    .btn-copy:active { transform: scale(0.9); opacity: 0.7; }

    .btn-crypto-send { width: 100%; background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.3); padding: 14px; border-radius: 12px; font-weight: 700; font-size: 15px; cursor: pointer; transition: 0.2s; display: flex; justify-content: center; align-items: center; gap: 8px; backdrop-filter: blur(4px); position: relative; z-index: 1; }
    .btn-crypto-send:active { transform: scale(0.98); background: rgba(255,255,255,0.25); }

    /* Modals & Forms */
    .modal-overlay { position: fixed; inset: 0; background: rgba(5, 16, 36, 0.6); z-index: 300; display: none; opacity: 0; transition: opacity 0.3s; }
    .modal-sheet { position: fixed; bottom: 0; left: 0; right: 0; background: var(--mob-bg); border-radius: 24px 24px 0 0; z-index: 301; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); padding: 24px; padding-bottom: max(24px, env(safe-area-inset-bottom)); max-height: 90vh; overflow-y: auto; }
    .modal-sheet.open { transform: translateY(0); }
    .modal-overlay.open { display: block; opacity: 1; }
    
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .modal-header h2 { margin: 0; font-size: 20px; font-weight: 800; color: var(--mob-text); }
    .modal-close-btn { background: var(--mob-surface); border: 1px solid var(--mob-border); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; }

    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--mob-text); margin-bottom: 8px; }
    .form-control { width: 100%; box-sizing: border-box; background: var(--mob-bg); border: 1px solid var(--mob-border); padding: 14px 16px; border-radius: 12px; font-size: 15px; outline: none; transition: 0.2s; font-family: monospace; color: var(--mob-text); }
    .form-control:focus { border-color: var(--mob-primary); box-shadow: 0 0 0 3px var(--mob-primary-dim); background: var(--mob-surface); }
    
    .amount-wrapper { position: relative; display: flex; align-items: center; }
    .amount-wrapper span { position: absolute; right: 16px; font-weight: 700; color: var(--mob-text-muted); font-size: 16px; }
    .amount-wrapper input { padding-right: 60px; font-weight: 800; font-size: 24px; color: var(--mob-primary); letter-spacing: -0.5px; }

    .btn-continue { background: var(--mob-primary); color: white; border: none; padding: 16px; border-radius: 16px; font-weight: 700; font-size: 16px; width: 100%; cursor: pointer; box-shadow: var(--mob-shadow-md); transition: transform 0.2s; display: block; text-align: center; }
    .btn-continue:active { transform: scale(0.98); }

    /* Confirmation Details */
    .confirm-details { background: var(--mob-surface); border-radius: 16px; border: 1px solid var(--mob-border); padding: 8px 20px; margin-bottom: 24px; }
    .confirm-row { display: flex; justify-content: space-between; align-items: center; padding: 16px 0; border-bottom: 1px solid var(--mob-border); }
    .confirm-row:last-child { border-bottom: none; }
    .confirm-label { font-size: 14px; color: var(--mob-text-muted); font-weight: 500; }
    .confirm-value { font-size: 14px; color: var(--mob-text); font-weight: 700; text-align: right; font-family: monospace; word-break: break-all; max-width: 60%; }
    .btn-submit-transfer { background: var(--mob-accent); color: var(--mob-primary); border: none; padding: 16px 20px; border-radius: 16px; font-weight: 800; font-size: 16px; width: 100%; cursor: pointer; box-shadow: 0 8px 20px rgba(0, 229, 196, 0.2); display: flex; justify-content: center; align-items: center; gap: 8px;}

    /* Success/Pending Screen */
    .success-overlay { position: fixed; inset: 0; background: var(--mob-bg); z-index: 400; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; text-align: center; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
    .success-overlay.show { opacity: 1; pointer-events: auto; }
    .success-icon-wrap { width: 80px; height: 80px; background: #fef3c7; color: #f59e0b; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; transform: scale(0.5); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    .success-overlay.show .success-icon-wrap { transform: scale(1); }
    .success-icon-wrap svg { width: 40px; height: 40px; stroke-width: 3px; }

    /* Custom Toast Notification */
    .toast-notif { position: fixed; top: 20px; left: 50%; transform: translateX(-50%) translateY(-100px); background: var(--mob-primary); color: white; padding: 12px 24px; border-radius: 20px; font-size: 14px; font-weight: 600; box-shadow: var(--mob-shadow-md); z-index: 999; transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); text-align: center; }
    .toast-notif.show { transform: translateX(-50%) translateY(0); }

    /* IOS MODAL STYLES */
    .ios-modal-overlay { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 1000; display: none; opacity: 0; transition: opacity 0.3s; }
    .ios-modal-sheet { position: fixed; bottom: 0; left: 0; right: 0; background: var(--mob-bg); border-radius: 24px 24px 0 0; z-index: 1001; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); padding: 32px 24px; padding-bottom: max(32px, env(safe-area-inset-bottom)); text-align: center; }
    .ios-modal-sheet.open { transform: translateY(0); }
    .ios-modal-overlay.open { display: block; opacity: 1; }
    .ios-modal-icon { width: 64px; height: 64px; background: #f3f4f6; border-radius: 16px; margin: 0 auto 20px auto; display: flex; align-items: center; justify-content: center; }
    .ios-modal-sheet h3 { font-size: 22px; font-weight: 800; color: var(--mob-text); margin-bottom: 12px; letter-spacing: -0.5px; }
    .ios-modal-sheet p { font-size: 16px; color: var(--mob-text-muted); line-height: 1.5; margin-bottom: 24px; }
    .ios-steps { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 16px; padding: 20px; text-align: left; margin-bottom: 24px; }
    .ios-step { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; font-size: 15px; font-weight: 600; color: var(--mob-text); }
    .ios-step:last-child { margin-bottom: 0; }
    .btn-got-it { background: var(--mob-text); color: var(--mob-bg); border: none; width: 100%; padding: 16px; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; }
  </style>
</head>
<body>

  <div id="toast" class="toast-notif">Address Copied</div>

  <header class="crypto-header">
    <div style="display: flex; align-items: center; gap: 12px;">
      <button class="btn-back" onclick="window.location.href='/dashboard'"><i data-lucide="arrow-left" style="width: 18px;"></i></button>
      <h1 style="margin: 0; font-size: 18px; font-weight: 800; color: var(--mob-text);">Crypto Wallets</h1>
    </div>
    
    <div style="display: flex; gap: 8px; align-items: center;">
      <button class="pwa-install-btn" style="display: none; background: var(--mob-accent); color: var(--mob-primary); border: none; padding: 6px 12px; border-radius: 20px; font-weight: 800; font-size: 13px; align-items: center; gap: 6px; cursor: pointer; box-shadow: var(--mob-shadow-sm);" onclick="triggerInstall()">
        App <i data-lucide="download" style="width: 14px; height: 14px;"></i>
      </button>
      <button class="mob-avatar-mini" onclick="openProfileMenu()">
        <%= typeof username !== 'undefined' && username ? username.charAt(0).toUpperCase() : 'U' %>
      </button>
    </div>
  </header>

  <main class="mob-main-content" style="padding-top: 10px; padding-bottom: 100px;">
    
    <% if (account.btc_status === 'ACTIVE') { %>
      <div class="crypto-card btc">
        <div class="crypto-card-header">
          <div class="cch-left">
            <div class="crypto-icon"><i data-lucide="bitcoin"></i></div>
            <div>
              <div class="crypto-subtitle">Bitcoin Wallet</div>
              <h2 class="crypto-title">BTC</h2>
            </div>
          </div>
        </div>
        <div class="crypto-balance"><%= btcBalance.toFixed(8) %></div>
        <div class="wallet-address-box">
          <div class="wallet-address"><%= account.btc_address %></div>
          <button class="btn-copy" onclick="copyToClipboard('<%= account.btc_address %>', this)"><i data-lucide="copy" style="width:18px;"></i></button>
        </div>
        <button class="btn-crypto-send" onclick="openSendModal('BTC', <%= btcBalance %>)">
          Send BTC <i data-lucide="arrow-up-right" style="width: 18px;"></i>
        </button>
      </div>
    <% } %>

    <% if (account.eth_status === 'ACTIVE') { %>
      <div class="crypto-card eth">
        <div class="crypto-card-header">
          <div class="cch-left">
            <div class="crypto-icon"><i data-lucide="hexagon"></i></div>
            <div>
              <div class="crypto-subtitle">Ethereum Wallet</div>
              <h2 class="crypto-title">ETH</h2>
            </div>
          </div>
        </div>
        <div class="crypto-balance"><%= ethBalance.toFixed(8) %></div>
        <div class="wallet-address-box">
          <div class="wallet-address"><%= account.eth_address %></div>
          <button class="btn-copy" onclick="copyToClipboard('<%= account.eth_address %>', this)"><i data-lucide="copy" style="width:18px;"></i></button>
        </div>
        <button class="btn-crypto-send" onclick="openSendModal('ETH', <%= ethBalance %>)">
          Send ETH <i data-lucide="arrow-up-right" style="width: 18px;"></i>
        </button>
      </div>
    <% } %>

  </main>

  <form id="cryptoForm" action="/send" method="POST" style="display: none;">
    <input type="hidden" name="currency_type" id="hiddenCurrency">
    <input type="hidden" name="recipient_name" id="hiddenAddress">
    <input type="hidden" name="amount" id="hiddenAmount">
  </form>

  <div class="modal-overlay" id="sendModalOverlay" onclick="closeSendModal()"></div>
  <div class="modal-sheet" id="sendModalSheet">
    <div class="modal-header">
      <h2 id="sendModalTitle">Send Crypto</h2>
      <button class="modal-close-btn" onclick="closeSendModal()"><i data-lucide="x" style="width: 16px; color: var(--mob-text);"></i></button>
    </div>
    
    <div class="form-group">
      <label>Destination Address</label>
      <input type="text" id="csAddress" class="form-control" placeholder="Paste wallet address" required>
    </div>

    <div class="form-group">
      <label>Amount</label>
      <div class="amount-wrapper">
        <input type="number" step="any" id="csAmount" class="form-control" placeholder="0.00000000" style="font-family: 'Inter', sans-serif;" required>
        <span id="csTicker">BTC</span>
      </div>
      <div style="font-size: 12px; color: var(--mob-text-muted); margin-top: 8px; text-align: right; font-weight: 600;" id="csMaxAmount">
        Available: 0.00
      </div>
    </div>
    
    <button class="btn-continue" onclick="reviewCryptoTransfer()">Review Transfer</button>
  </div>

  <div class="modal-overlay" id="reviewOverlay" onclick="closeReviewModal()"></div>
  <div class="modal-sheet" id="reviewSheet">
    <div class="modal-header">
      <h2>Confirm Transaction</h2>
      <button class="modal-close-btn" onclick="closeReviewModal()"><i data-lucide="x" style="width: 16px; color: var(--mob-text);"></i></button>
    </div>
    
    <div class="confirm-details">
      <div class="confirm-row">
        <div class="confirm-label">Asset</div>
        <div class="confirm-value" id="rvCurrency" style="font-family: 'Inter', sans-serif;">BTC</div>
      </div>
      <div class="confirm-row">
        <div class="confirm-label">Destination</div>
        <div class="confirm-value" id="rvAddress">0x...</div>
      </div>
      <div class="confirm-row">
        <div class="confirm-label">Amount</div>
        <div class="confirm-value" id="rvAmount" style="font-size: 18px; color: var(--mob-primary); font-family: 'Inter', sans-serif;">0.00</div>
      </div>
    </div>

    <button class="btn-submit-transfer" id="submitBtn" onclick="processCryptoTransfer()">Send Securely</button>
  </div>

  <div class="ios-modal-overlay" id="iosModalOverlay" onclick="closeIOSModal()"></div>
  <div class="ios-modal-sheet" id="iosModalSheet">
    <div class="ios-modal-icon">
      <img src="https://cdn-icons-png.flaticon.com/512/6202/6202860.png" alt="Clear.Bank" style="width: 40px; height: 40px;">
    </div>
    <h3>Install Clear.Bank App</h3>
    <p>Install this application on your home screen for quick and easy access when you're on the go.</p>
    <div class="ios-steps">
      <div class="ios-step">
        <span>1.</span>
        <span>Tap the <strong>Share</strong> button at the bottom of Safari.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--mob-text);"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
      </div>
      <div class="ios-step">
        <span>2.</span>
        <span>Scroll down and select <strong>Add to Home Screen</strong>.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--mob-text);"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
      </div>
    </div>
    <button class="btn-got-it" onclick="closeIOSModal()">Got it!</button>
  </div>

  <div class="success-overlay" id="successScreen">
    <div class="success-icon-wrap"><i data-lucide="clock"></i></div>
    <h2 style="margin: 0 0 8px 0; font-size: 24px; font-weight: 800; color: var(--mob-text); letter-spacing: -0.5px;">Transfer Pending</h2>
    <p style="margin: 0 0 32px 0; font-size: 15px; color: var(--mob-text-muted); max-width: 80%;">Your transaction has been broadcasted and is awaiting network confirmation.</p>
    
    <h1 style="font-size: 40px; font-weight: 800; color: var(--mob-text); margin: 0 0 4px 0; letter-spacing: -1px;" id="successAmount">0.00</h1>
    <p style="font-size: 14px; font-weight: 600; color: var(--mob-text-muted); margin: 0 0 40px 0; font-family: monospace; word-break: break-all; max-width: 80%;" id="successAddress">to 0x...</p>

    <button class="btn-continue" style="background: var(--mob-primary-dim); color: var(--mob-primary); width: calc(100% - 40px); margin:0 20px;" onclick="window.location.href='/transfers'">View in Ledger</button>
  </div>

  <nav class="mob-bottom-nav">
    <a href="/dashboard" class="mob-nav-link"><span class="mob-nav-icon"><i data-lucide="home"></i></span>Home</a>
    <a href="/account" class="mob-nav-link"><span class="mob-nav-icon"><i data-lucide="credit-card"></i></span>Accounts</a>
    <a href="/transfers" class="mob-nav-link"><span class="mob-nav-icon"><i data-lucide="arrow-right-left"></i></span>Transactions</a>
    <a href="/support" class="mob-nav-link"><span class="mob-nav-icon"><i data-lucide="headphones"></i></span>Support</a>
  </nav>

  <script>
    lucide.createIcons();

    let currentCoin = '';
    let currentMaxBalance = 0;

    function showToast(msg, isError = false) {
      const toast = document.getElementById('toast');
      toast.innerText = msg;
      if(isError) toast.style.background = '#ef4444';
      else toast.style.background = 'var(--mob-primary)';
      
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    async function copyToClipboard(text, btnElement) {
      try {
        await navigator.clipboard.writeText(text);
        const originalContent = btnElement.innerHTML;
        btnElement.innerHTML = '<i data-lucide="check" style="width: 18px; color: #10b981;"></i>';
        lucide.createIcons(); 
        showToast('Address Copied');
        setTimeout(() => {
          btnElement.innerHTML = originalContent;
          lucide.createIcons(); 
        }, 2000);
      } catch (err) {
        showToast('Failed to copy', true);
      }
    }

    function openSendModal(coin, maxBalance) {
      currentCoin = coin.toLowerCase();
      currentMaxBalance = maxBalance;

      document.getElementById('sendModalTitle').innerText = 'Send ' + coin;
      document.getElementById('csTicker').innerText = coin;
      document.getElementById('csMaxAmount').innerText = 'Available: ' + maxBalance.toFixed(8) + ' ' + coin;
      
      document.getElementById('csAddress').value = '';
      document.getElementById('csAmount').value = '';
      
      document.getElementById('sendModalOverlay').classList.add('open');
      setTimeout(() => document.getElementById('sendModalSheet').classList.add('open'), 10);
    }

    function closeSendModal() {
      document.getElementById('sendModalSheet').classList.remove('open');
      setTimeout(() => document.getElementById('sendModalOverlay').classList.remove('open'), 300);
    }

    function reviewCryptoTransfer() {
      const address = document.getElementById('csAddress').value.trim();
      const amountInput = document.getElementById('csAmount').value;
      const amount = parseFloat(amountInput);

      if (!address || isNaN(amount) || amount <= 0) {
        showToast("Please fill out all fields correctly.", true);
        return;
      }

      if (amount > currentMaxBalance) {
        showToast("Error: Insufficient funds in your account.", true);
        return;
      }

      // Populate hidden form
      document.getElementById('hiddenCurrency').value = currentCoin;
      document.getElementById('hiddenAddress').value = address;
      document.getElementById('hiddenAmount').value = amount;

      // Populate Review UI
      document.getElementById('rvCurrency').innerText = currentCoin.toUpperCase();
      document.getElementById('rvAddress').innerText = address.substring(0, 10) + '...' + address.substring(address.length - 8);
      document.getElementById('rvAmount').innerText = amount.toFixed(8) + ' ' + currentCoin.toUpperCase();

      closeSendModal();
      setTimeout(() => {
        document.getElementById('reviewOverlay').classList.add('open');
        setTimeout(() => document.getElementById('reviewSheet').classList.add('open'), 10);
      }, 350);
    }

    function closeReviewModal() {
      document.getElementById('reviewSheet').classList.remove('open');
      setTimeout(() => document.getElementById('reviewOverlay').classList.remove('open'), 300);
    }

    function processCryptoTransfer() {
      const btn = document.getElementById('submitBtn');
      btn.innerHTML = '<i data-lucide="loader-2" style="animation: spin 1s linear infinite; width: 20px;"></i> Broadcasting...';
      lucide.createIcons();
      btn.style.opacity = '0.8';
      btn.style.pointerEvents = 'none';
      setTimeout(() => {
        closeReviewModal();
        
        setTimeout(() => {
          const amount = parseFloat(document.getElementById('hiddenAmount').value);
          const address = document.getElementById('hiddenAddress').value;
          
          document.getElementById('successAmount').innerText = amount.toFixed(8) + ' ' + currentCoin.toUpperCase();
          document.getElementById('successAddress').innerText = 'To: ' + address;
          
          document.getElementById('successScreen').classList.add('show');
          
          // Submit to backend
          document.getElementById('cryptoForm').submit();
          
        }, 300); 
      }, 2000);
    }

    // ADVANCED PWA INSTALL LOGIC (APPLE BYPASS)
    let deferredPrompt;
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;
    
    if (!isStandalone) {
      if (isIOS) {
        document.querySelectorAll('.pwa-install-btn').forEach(btn => { btn.style.display = 'flex'; });
      } else {
        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;
          document.querySelectorAll('.pwa-install-btn').forEach(btn => { btn.style.display = 'flex'; });
        });
      }
    }

    function triggerInstall() {
      if (isIOS) {
        document.getElementById('iosModalOverlay').classList.add('open');
        setTimeout(() => document.getElementById('iosModalSheet').classList.add('open'), 10);
      } else if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then((choiceResult) => { deferredPrompt = null; });
      }
    }

    function closeIOSModal() {
      document.getElementById('iosModalSheet').classList.remove('open');
      setTimeout(() => document.getElementById('iosModalOverlay').classList.remove('open'), 300);
    }
  </script>

  <%- include('partials/profile_menu') %>
</body>
</html>