<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Clear.Bank | Home</title>
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="white" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/mobile.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <style>
    body { background-color: var(--mob-bg); }
    
    /* PC Desktop Constraint for Mobile App View */
    @media (min-width: 768px) {
      body { max-width: 480px; margin: 0 auto; border-left: 1px solid var(--mob-border); border-right: 1px solid var(--mob-border); box-shadow: 0 0 50px rgba(0,0,0,0.1); position: relative; min-height: 100vh; }
      .mob-bottom-nav, .toast-notif, .ios-modal-sheet { max-width: 480px; margin: 0 auto; left: 0; right: 0; }
    }
    
    .mob-header-custom { display: flex; align-items: center; padding: 16px 20px; padding-top: max(20px, env(safe-area-inset-top)); gap: 16px; justify-content: space-between; }
    .mob-greeting { display: flex; flex-direction: column; justify-content: center; }
    .mob-greeting-sub { font-size: 13px; color: var(--mob-text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .mob-greeting-name { font-size: 18px; font-weight: 800; letter-spacing: -0.5px; color: var(--mob-text); line-height: 1.2; margin-top: 2px;}

    .mob-action-row-centered { display: flex; justify-content: space-evenly; padding: 0 10px; margin-bottom: 40px; margin-top: 10px; }
    .mob-action-item { display: flex; flex-direction: column; align-items: center; gap: 8px; text-decoration: none; color: var(--mob-text); }
    .mob-action-circle { width: 56px; height: 56px; background: var(--mob-surface); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--mob-primary); box-shadow: var(--mob-shadow-md); transition: transform 0.2s; border: 1px solid var(--mob-border); }
    .mob-action-circle:active { transform: scale(0.95); }
    .mob-action-circle svg { width: 24px; height: 24px; stroke-width: 2px; }
    .mob-action-label { font-size: 13px; font-weight: 600; }
    .mob-nav-icon svg { width: 24px; height: 24px; stroke-width: 2px; margin-bottom: 2px; }

    /* IOS MODAL STYLES */
    .ios-modal-overlay { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 1000; display: none; opacity: 0; transition: opacity 0.3s; }
    .ios-modal-sheet { position: fixed; bottom: 0; left: 0; right: 0; background: var(--mob-bg); border-radius: 24px 24px 0 0; z-index: 1001; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); padding: 32px 24px; padding-bottom: max(32px, env(safe-area-inset-bottom)); text-align: center; }
    .ios-modal-sheet.open { transform: translateY(0); }
    .ios-modal-overlay.open { display: block; opacity: 1; }
    .ios-modal-icon { width: 64px; height: 64px; background: #f3f4f6; border-radius: 16px; margin: 0 auto 20px auto; display: flex; align-items: center; justify-content: center; }
    .ios-modal-icon img { width: 40px; height: 40px; }
    .ios-modal-sheet h3 { font-size: 22px; font-weight: 800; color: var(--mob-text); margin-bottom: 12px; letter-spacing: -0.5px; }
    .ios-modal-sheet p { font-size: 16px; color: var(--mob-text-muted); line-height: 1.5; margin-bottom: 24px; }
    .ios-steps { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 16px; padding: 20px; text-align: left; margin-bottom: 24px; }
    .ios-step { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; font-size: 15px; font-weight: 600; color: var(--mob-text); }
    .ios-step:last-child { margin-bottom: 0; }
    .ios-step svg { color: var(--mob-primary); width: 24px; height: 24px; }
    .btn-got-it { background: var(--mob-text); color: var(--mob-bg); border: none; width: 100%; padding: 16px; border-radius: 16px; font-size: 16px; font-weight: 700; cursor: pointer; }
  </style>
</head>
<body>

  <header class="mob-header-custom">
    <div style="display: flex; align-items: center; gap: 12px;">
      <div style="width: 40px; height: 40px; background: var(--mob-surface); border: 1px solid var(--mob-border); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 16px; color: var(--mob-text); box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
        C.B
      </div>
      <div class="mob-greeting">
        <span class="mob-greeting-sub">Welcome back,</span>
        <strong class="mob-greeting-name"><%= typeof account !== 'undefined' && account.name ? account.name : 'User' %></strong>
      </div>
    </div>
    
    <div style="display: flex; gap: 12px; align-items: center;">
      <button class="pwa-install-btn" style="display: none; background: var(--mob-accent); color: var(--mob-primary); border: none; padding: 6px 12px; border-radius: 20px; font-weight: 800; font-size: 13px; align-items: center; gap: 6px; cursor: pointer; box-shadow: var(--mob-shadow-sm);" onclick="triggerInstall()">
        App <i data-lucide="download" style="width: 14px; height: 14px;"></i>
      </button>
      <button onclick="openProfileMenu()" class="mob-avatar-mini" style="width: 42px; height: 42px; font-size: 16px;">
        <%= typeof username !== 'undefined' && username ? username.charAt(0).toUpperCase() : 'U' %>
      </button>
    </div>
  </header>

  <main class="mob-main-content" style="padding-top: 0; padding-bottom: 100px;">
    
    <div style="margin-top: 20px; margin-bottom: 40px; text-align: center;">
      <div style="font-size: 14px; font-weight: 600; color: var(--mob-text-muted);">Total Balance · EUR</div>
      <div style="font-size: 56px; font-weight: 800; letter-spacing: -1px; margin-bottom: 16px; color: var(--mob-text);">
        €<%= typeof fiatBalance !== 'undefined' ? fiatBalance.toLocaleString('en-US', {minimumFractionDigits: 2}) : '0.00' %>
      </div>
      <button style="background: var(--mob-primary-dim); color: var(--mob-primary); border: none; padding: 10px 24px; border-radius: 20px; font-weight: 700; font-size: 14px; cursor: pointer;">Active Accounts</button>
    </div>

    <div class="mob-action-row-centered">
      <a href="/receive" class="mob-action-item">
        <div class="mob-action-circle"><i data-lucide="plus"></i></div>
        <span class="mob-action-label">Add money</span>
      </a>
      <a href="/send" class="mob-action-item">
        <div class="mob-action-circle"><i data-lucide="arrow-right-left"></i></div>
        <span class="mob-action-label">Make a payment</span>
      </a>
      <a href="/account" class="mob-action-item">
        <div class="mob-action-circle"><i data-lucide="more-horizontal"></i></div>
        <span class="mob-action-label">Details</span>
      </a>
    </div>

    <div style="display: flex; justify-content: space-between; padding: 0 20px 14px 20px; align-items: center;">
      <h3 style="margin: 0; font-size: 18px; font-weight: 800; color: var(--mob-text); letter-spacing: -0.5px;">Recent transactions</h3>
    </div>

    <div style="background: var(--mob-surface); border-radius: var(--mob-radius-lg); border: 1px solid var(--mob-border); margin: 0 20px 24px 20px; padding: 12px 20px; box-shadow: var(--mob-shadow-sm);">
      <% if (!transactions || transactions.length === 0) { %>
        <div style="text-align: center; color: var(--mob-text-muted); font-size: 14px; padding: 30px 0; font-weight: 500;">No recent activity</div>
      <% } else { %>
        <% transactions.slice(0, 4).forEach(tx => { 
            const isHisa = tx.currency === 'HISA';
            const isCrypto = tx.currency === 'BTC' || tx.currency === 'ETH';
            let statusColor = '#10b981'; 
            if (tx.status && tx.status.toUpperCase() === 'PENDING') statusColor = '#f59e0b'; 
            if (tx.status && tx.status.toUpperCase() === 'DECLINED') statusColor = '#ef4444'; 
        %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 0; border-bottom: 1px solid var(--mob-border);">
            <div style="display: flex; align-items: center; gap: 16px;">
              <div style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; <%= isHisa ? 'background: var(--mob-primary-dim); color: var(--mob-primary);' : (isCrypto ? 'background: #fef3c7; color: #d97706;' : 'background: #f1f5f9; color: var(--mob-primary);') %>">
                <% if (isHisa) { %><i data-lucide="trending-up" style="width: 20px;"></i><% } 
                   else if (tx.currency === 'BTC') { %><i data-lucide="bitcoin" style="width: 20px;"></i><% } 
                   else if (tx.currency === 'ETH') { %><i data-lucide="hexagon" style="width: 20px;"></i><% } 
                   else { %><i data-lucide="landmark" style="width: 20px;"></i><% } %>
              </div>
              <div>
                <h4 style="margin: 0 0 4px 0; font-size: 16px; font-weight: 700; color: var(--mob-text);"><%= tx.name %></h4>
                <p style="margin: 0; font-size: 13px; color: var(--mob-text-muted); font-weight: 500;">
                  <%= tx.date %> • <span style="color: <%= statusColor %>; font-weight: 700;"><%= tx.status || 'COMPLETED' %></span>
                </p>
              </div>
            </div>
            <div style="font-size: 16px; font-weight: 700; <%= tx.direction === 'INCOMING' ? 'color: #10b981;' : 'color: var(--mob-text);' %>">
              <%= tx.direction === 'INCOMING' ? '+' : '-' %><%= tx.amountStr %>
            </div>
          </div>
        <% }) %>
      <% } %>
      <div style="padding-top: 16px; text-align: center;">
        <a href="/transfers" style="color: var(--mob-primary); font-size: 14px; font-weight: 700; text-decoration: none;">See all history</a>
      </div>
    </div>

  </main>

  <div class="ios-modal-overlay" id="iosModalOverlay" onclick="closeIOSModal()"></div>
  <div class="ios-modal-sheet" id="iosModalSheet">
    <div class="ios-modal-icon">
      <img src="https://cdn-icons-png.flaticon.com/512/6202/6202860.png" alt="ClearBank Logo" style="width: 40px; height: 40px;">
    </div>
    <h3>Install Clear.Bank App</h3>
    <p>Install this application on your home screen for quick and easy access when you're on the go.</p>
    <div class="ios-steps">
      <div class="ios-step">
        <span>1.</span>
        <span>Tap the <strong>Share</strong> button at the bottom of Safari.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--mob-text);"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
      </div>
      <div class="ios-step">
        <span>2.</span>
        <span>Scroll down and select <strong>Add to Home Screen</strong>.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--mob-text);"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
      </div>
    </div>
    <button class="btn-got-it" onclick="closeIOSModal()">Got it!</button>
  </div>

  <nav class="mob-bottom-nav">
    <a href="/dashboard" class="mob-nav-link active"><span class="mob-nav-icon"><i data-lucide="home"></i></span>Home</a>
    <a href="/account" class="mob-nav-link"><span class="mob-nav-icon"><i data-lucide="credit-card"></i></span>Accounts</a>
    <a href="/transfers" class="mob-nav-link"><span class="mob-nav-icon"><i data-lucide="arrow-right-left"></i></span>Transactions</a>
    <a href="/support" class="mob-nav-link"><span class="mob-nav-icon"><i data-lucide="headphones"></i></span>Support</a>
  </nav>

  <script>
    lucide.createIcons();

    // ADVANCED PWA INSTALL LOGIC (APPLE BYPASS)
    let deferredPrompt;
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;

    if (!isStandalone) {
      if (isIOS) {
        document.querySelectorAll('.pwa-install-btn').forEach(btn => { btn.style.display = 'flex'; });
      } else {
        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;
          document.querySelectorAll('.pwa-install-btn').forEach(btn => { btn.style.display = 'flex'; });
        });
      }
    }

    function triggerInstall() {
      if (isIOS) {
        document.getElementById('iosModalOverlay').classList.add('open');
        setTimeout(() => document.getElementById('iosModalSheet').classList.add('open'), 10);
      } else if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then((choiceResult) => { deferredPrompt = null; });
      }
    }

    function closeIOSModal() {
      document.getElementById('iosModalSheet').classList.remove('open');
      setTimeout(() => document.getElementById('iosModalOverlay').classList.remove('open'), 300);
    }
  </script>

  <%- include('partials/profile_menu') %>
</body>
</html>