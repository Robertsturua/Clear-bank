<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Clear.Bank | Add Money</title>
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="white" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/mobile.css">
  
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <style>
    body { 
      background-color: var(--mob-bg);
      overflow-x: hidden; 
    }
    
    /* PC Desktop Constraint */
    @media (min-width: 768px) {
      body { 
        max-width: 480px; 
        margin: 0 auto; 
        border-left: 1px solid var(--mob-border); 
        border-right: 1px solid var(--mob-border); 
        box-shadow: 0 0 50px rgba(0,0,0,0.1); 
        position: relative; 
        min-height: 100vh; 
      }
      .mob-bottom-nav, .toast-notif, .ios-modal-sheet { 
        max-width: 480px; 
        margin: 0 auto; 
        left: 0; 
        right: 0; 
      }
    }
    
    .receive-header {
      display: flex;
      align-items: center; 
      justify-content: space-between;
      padding: 16px 20px; 
      padding-top: max(20px, env(safe-area-inset-top));
      background: var(--mob-bg); 
      position: sticky; 
      top: 0; 
      z-index: 100;
    }
    
    .receive-header h1 { 
      margin: 0;
      font-size: 20px; 
      font-weight: 800; 
      color: var(--mob-text);
    }
    
    .btn-back { 
      background: var(--mob-surface);
      border: 1px solid var(--mob-border); 
      width: 36px; 
      height: 36px; 
      border-radius: 50%; 
      display: flex;
      align-items: center; 
      justify-content: center; 
      cursor: pointer; 
      color: var(--mob-text);
      box-shadow: var(--mob-shadow-sm);
    }
    
    .section-title { 
      margin: 20px 24px 12px 24px;
      font-size: 13px; 
      font-weight: 700;
      color: var(--mob-text-muted); 
      text-transform: uppercase; 
      letter-spacing: 0.5px;
    }

    /* Bank Details Card */
    .bank-details-card {
      background: var(--mob-surface);
      margin: 0 20px 24px 20px; 
      border-radius: 20px; 
      padding: 24px 20px; 
      border: 1px solid var(--mob-border); 
      box-shadow: var(--mob-shadow-sm); 
      position: relative; 
      overflow: hidden;
    }
    
    .qr-placeholder { 
      width: 64px; 
      height: 64px;
      background: var(--mob-bg); 
      border: 1px dashed var(--mob-border);
      border-radius: 12px; 
      display: flex; 
      align-items: center; 
      justify-content: center; 
      margin: 0 auto 24px auto;
      color: var(--mob-primary);
    }
    
    .detail-row { 
      display: flex;
      justify-content: space-between; 
      align-items: flex-start; 
      padding: 16px 0;
      border-bottom: 1px solid var(--mob-border);
    }
    
    .detail-row:last-child { 
      border-bottom: none; 
      padding-bottom: 0;
    }
    
    .detail-label { 
      font-size: 13px; 
      color: var(--mob-text-muted);
      font-weight: 600; 
      margin-bottom: 4px;
    }
    
    .detail-value { 
      font-size: 16px;
      font-weight: 700; 
      color: var(--mob-text); 
      font-family: monospace; 
      letter-spacing: 0.5px;
    }
    
    .copy-btn {
      background: var(--mob-bg);
      color: var(--mob-primary);
      border: 1px solid var(--mob-border); 
      width: 36px; 
      height: 36px; 
      border-radius: 10px; 
      display: flex; 
      align-items: center; 
      justify-content: center; 
      cursor: pointer;
      transition: 0.2s;
      flex-shrink: 0;
    }
    
    .copy-btn svg { 
      width: 16px;
      height: 16px; 
      stroke-width: 2.5px;
    }

    .btn-share {
      background: var(--mob-primary-dim); 
      color: var(--mob-primary);
      border: none; 
      padding: 14px 20px;
      border-radius: 16px; 
      font-weight: 700; 
      font-size: 15px; 
      width: calc(100% - 40px); 
      margin: 0 20px; 
      cursor: pointer;
      display: flex; 
      align-items: center;
      justify-content: center; 
      gap: 8px; 
      transition: transform 0.2s;
    }
    
    .btn-share:active { 
      transform: scale(0.98);
    }

    /* Custom Toast Notification */
    .toast-notif { 
      position: fixed;
      top: 20px;
      left: 50%; 
      transform: translateX(-50%) translateY(-100px); 
      background: var(--mob-primary); 
      color: white; 
      padding: 12px 24px; 
      border-radius: 20px; 
      font-size: 14px; 
      font-weight: 600;
      box-shadow: var(--mob-shadow-md);
      z-index: 999; 
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); 
      text-align: center; 
      width: auto; 
      white-space: nowrap;
    }
    
    .toast-notif.show { 
      transform: translateX(-50%) translateY(0);
    }

    /* IOS MODAL STYLES */
    .ios-modal-overlay { 
      position: fixed; 
      inset: 0; 
      background: rgba(0, 0, 0, 0.5); 
      backdrop-filter: blur(4px); 
      -webkit-backdrop-filter: blur(4px); 
      z-index: 1000; 
      display: none; 
      opacity: 0; 
      transition: opacity 0.3s; 
    }
    .ios-modal-sheet { 
      position: fixed; 
      bottom: 0; 
      left: 0; 
      right: 0; 
      background: var(--mob-bg); 
      border-radius: 24px 24px 0 0; 
      z-index: 1001; 
      transform: translateY(100%); 
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); 
      padding: 32px 24px; 
      padding-bottom: max(32px, env(safe-area-inset-bottom)); 
      text-align: center; 
    }
    .ios-modal-sheet.open { transform: translateY(0); }
    .ios-modal-overlay.open { display: block; opacity: 1; }
    
    .ios-modal-icon { 
      width: 64px; 
      height: 64px; 
      background: #f3f4f6; 
      border-radius: 16px; 
      margin: 0 auto 20px auto; 
      display: flex; 
      align-items: center; 
      justify-content: center; 
    }
    .ios-modal-sheet h3 { 
      font-size: 22px; 
      font-weight: 800; 
      color: var(--mob-text); 
      margin-bottom: 12px; 
      letter-spacing: -0.5px; 
    }
    .ios-modal-sheet p { 
      font-size: 16px; 
      color: var(--mob-text-muted); 
      line-height: 1.5; 
      margin-bottom: 24px; 
    }
    .ios-steps { 
      background: #f9fafb; 
      border: 1px solid #e5e7eb; 
      border-radius: 16px; 
      padding: 20px; 
      text-align: left; 
      margin-bottom: 24px; 
    }
    .ios-step { 
      display: flex; 
      align-items: center; 
      gap: 12px; 
      margin-bottom: 16px; 
      font-size: 15px; 
      font-weight: 600; 
      color: var(--mob-text); 
    }
    .ios-step:last-child { margin-bottom: 0; }
    .btn-got-it { 
      background: var(--mob-text); 
      color: var(--mob-bg); 
      border: none; 
      width: 100%; 
      padding: 16px; 
      border-radius: 16px; 
      font-size: 16px; 
      font-weight: 700; 
      cursor: pointer; 
    }
  </style>
</head>
<body>

  <div id="toast" class="toast-notif">Message</div>

  <header class="receive-header">
    <div style="display: flex; align-items: center; gap: 12px;">
      <button class="btn-back" onclick="window.history.back()">
        <i data-lucide="arrow-left" style="width: 18px;"></i>
      </button>
      <svg width="24" height="24" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" style="border-radius: 6px;">
        <defs>
          <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#000000"/><stop offset="100%" stop-color="#1a1a1a"/></linearGradient>
          <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#FF3385"/><stop offset="100%" stop-color="#00E5C4"/></linearGradient>
        </defs>
        <rect width="512" height="512" rx="112" fill="url(#bg)"/>
        <rect x="32" y="32" width="448" height="448" rx="88" fill="none" stroke="url(#accent)" stroke-width="16"/>
        <text x="50%" y="54%" font-family="-apple-system, BlinkMacSystemFont, 'Inter', sans-serif" font-size="220" font-weight="800" fill="#ffffff" text-anchor="middle" dominant-baseline="middle" letter-spacing="-8">C.B</text>
      </svg>
      <h1>Add Money</h1>
    </div>
    
    <div style="display: flex; gap: 8px; align-items: center;">
      <button class="pwa-install-btn" style="display: none; background: var(--mob-accent); color: var(--mob-primary); border: none; padding: 6px 12px; border-radius: 20px; font-weight: 800; font-size: 13px; align-items: center; gap: 6px; cursor: pointer; box-shadow: var(--mob-shadow-sm);" onclick="triggerInstall()">
        App <i data-lucide="download" style="width: 14px; height: 14px;"></i>
      </button>
      <button class="mob-avatar-mini" onclick="openProfileMenu()">
        <%= typeof username !== 'undefined' && username ? username.charAt(0).toUpperCase() : 'U' %>
      </button>
    </div>
  </header>

  <main class="mob-main-content" style="padding-top: 10px; padding-bottom: 100px;">
    
    <h3 class="section-title">Bank Transfer Details</h3>
    <div class="bank-details-card">
      <div class="qr-placeholder">
        <i data-lucide="qr-code" style="width: 32px; height: 32px;"></i>
      </div>
      
      <div class="detail-row">
        <div>
          <div class="detail-label">Account Holder</div>
          <div class="detail-value"><%= account.name %></div>
        </div>
      </div>
      
      <div class="detail-row">
        <div>
          <div class="detail-label">IBAN</div>
          <div class="detail-value"><%= account.iban %></div>
        </div>
        <button class="copy-btn" onclick="copyToClipboard('<%= account.iban %>', this)">
          <i data-lucide="copy"></i>
        </button>
      </div>
      
      <div class="detail-row">
        <div>
          <div class="detail-label">BIC / SWIFT</div>
          <div class="detail-value"><%= account.swift %></div>
        </div>
        <button class="copy-btn" onclick="copyToClipboard('<%= account.swift %>', this)">
          <i data-lucide="copy"></i>
        </button>
      </div>
    </div>

    <button class="btn-share" onclick="showToast('Opening Share menu...')">
      <i data-lucide="share" style="width: 18px;"></i>
      Share Account Details
    </button>

  </main>

  <div class="ios-modal-overlay" id="iosModalOverlay" onclick="closeIOSModal()"></div>
  <div class="ios-modal-sheet" id="iosModalSheet">
    <div class="ios-modal-icon">
      <svg width="40" height="40" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" style="border-radius: 8px;">
        <defs>
          <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#000000"/><stop offset="100%" stop-color="#1a1a1a"/></linearGradient>
          <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#FF3385"/><stop offset="100%" stop-color="#00E5C4"/></linearGradient>
        </defs>
        <rect width="512" height="512" rx="112" fill="url(#bg)"/>
        <rect x="32" y="32" width="448" height="448" rx="88" fill="none" stroke="url(#accent)" stroke-width="16"/>
        <text x="50%" y="54%" font-family="-apple-system, BlinkMacSystemFont, 'Inter', sans-serif" font-size="220" font-weight="800" fill="#ffffff" text-anchor="middle" dominant-baseline="middle" letter-spacing="-8">C.B</text>
      </svg>
    </div>
    <h3>Install Clear.Bank App</h3>
    <p>Install this application on your home screen for quick and easy access when you're on the go.</p>
    <div class="ios-steps">
      <div class="ios-step">
        <span>1.</span>
        <span>Tap the <strong>Share</strong> button at the bottom of Safari.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--mob-text);"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
      </div>
      <div class="ios-step">
        <span>2.</span>
        <span>Scroll down and select <strong>Add to Home Screen</strong>.</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; color: var(--mob-text);"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
      </div>
    </div>
    <button class="btn-got-it" onclick="closeIOSModal()">Got it!</button>
  </div>

  <nav class="mob-bottom-nav">
    <a href="/dashboard" class="mob-nav-link">
      <span class="mob-nav-icon"><i data-lucide="home"></i></span>
      Home
    </a>
    <a href="/account" class="mob-nav-link">
      <span class="mob-nav-icon"><i data-lucide="credit-card"></i></span>
      Accounts
    </a>
    <a href="/transfers" class="mob-nav-link">
      <span class="mob-nav-icon"><i data-lucide="arrow-right-left"></i></span>
      Transactions
    </a>
    <a href="/support" class="mob-nav-link">
      <span class="mob-nav-icon"><i data-lucide="headphones"></i></span>
      Support
    </a>
  </nav>

  <script>
    lucide.createIcons();

    function showToast(msg) {
      const toast = document.getElementById('toast');
      toast.innerText = msg;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    async function copyToClipboard(text, btnElement) {
      try {
        await navigator.clipboard.writeText(text);
        const originalContent = btnElement.innerHTML;
        btnElement.innerHTML = '<i data-lucide="check" style="width: 16px; height: 16px; stroke-width: 3px;"></i>';
        lucide.createIcons(); 
        
        btnElement.style.background = 'var(--mob-primary-dim)';
        btnElement.style.color = 'var(--mob-primary)';
        
        showToast('Copied to clipboard');

        setTimeout(() => {
          btnElement.innerHTML = originalContent;
          lucide.createIcons(); 
          btnElement.style.background = 'var(--mob-bg)';
          btnElement.style.color = 'var(--mob-primary)';
        }, 2000);
      } catch (err) {
        showToast('Failed to copy');
      }
    }

    // ADVANCED PWA INSTALL LOGIC (APPLE BYPASS)
    let deferredPrompt;
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;

    if (!isStandalone) {
      if (isIOS) {
        document.querySelectorAll('.pwa-install-btn').forEach(btn => { btn.style.display = 'flex'; });
      } else {
        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;
          document.querySelectorAll('.pwa-install-btn').forEach(btn => { btn.style.display = 'flex'; });
        });
      }
    }

    function triggerInstall() {
      if (isIOS) {
        document.getElementById('iosModalOverlay').classList.add('open');
        setTimeout(() => document.getElementById('iosModalSheet').classList.add('open'), 10);
      } else if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then((choiceResult) => { deferredPrompt = null; });
      }
    }

    function closeIOSModal() {
      document.getElementById('iosModalSheet').classList.remove('open');
      setTimeout(() => document.getElementById('iosModalOverlay').classList.remove('open'), 300);
    }
  </script>

  <%- include('partials/profile_menu') %>
</body>
</html>